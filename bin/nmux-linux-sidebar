#!/usr/bin/env node
// nmux-linux-sidebar — live project list pane.
// Sections: open windows (with × close button) → closed registered projects
// (clickable to reopen) → "+ new project" → "⊗ kill nmux-linux".
// Writes a clickmap consumed by `nmux-linux click <y> <x>`.

const { spawnSync } = require('child_process');
const fs = require('fs');
const path = require('path');
const os = require('os');

const SESSION = process.env.NMUX_LINUX_SESSION || 'nmux-linux';
const CONFIG_DIR = path.join(os.homedir(), '.config', 'nmux-linux');
const CONFIG_PATH = path.join(CONFIG_DIR, 'projects.json');
const STATE_PATH = path.join(CONFIG_DIR, 'state.json');
const CLICKMAP_DIR = path.join(CONFIG_DIR, 'clickmaps');
// Per-pane clickmap so a click in pane A is never resolved against pane B's
// stale rows. tmux sets $TMUX_PANE for processes inside a pane.
const PANE_ID = (process.env.TMUX_PANE || 'default').replace(/[^A-Za-z0-9_%-]/g, '_');
const CLICKMAP_PATH = path.join(CLICKMAP_DIR, `${PANE_ID}.txt`);
const SCAN_ROOTS = [path.join(os.homedir(), 'projects')];
const DEFAULT_SIDEBAR_WIDTH = 26;
const SIDEBAR_MIN_WIDTH = 16;
const SIDEBAR_COMPACT_WIDTH = 20;

function clampInt(n, min, max) {
  const v = Math.floor(Number(n));
  const lo = Math.floor(Number(min));
  const hi = Math.floor(Number(max));
  if (!Number.isFinite(v)) return lo;
  return Math.max(lo, Math.min(hi, v));
}

function responsiveSidebarWidth(winW, configured = DEFAULT_SIDEBAR_WIDTH) {
  const max = clampInt(configured || DEFAULT_SIDEBAR_WIDTH, 12, 40);
  const w = Number(winW);
  if (!Number.isFinite(w) || w <= 0) return max;
  if (w < 72) return Math.min(max, SIDEBAR_MIN_WIDTH);
  if (w < 104) return Math.min(max, SIDEBAR_COMPACT_WIDTH);
  return max;
}

// Atomic write helper — same pattern used by the main nmux-linux script.
function writeAtomic(filePath, content) {
  const dir = path.dirname(filePath);
  fs.mkdirSync(dir, { recursive: true });
  const tmp = path.join(dir, '.' + path.basename(filePath) + '.tmp.' + process.pid + '.' + Date.now());
  fs.writeFileSync(tmp, content);
  fs.renameSync(tmp, filePath);
}
const DISCOVER_LIMIT = 30;
const DISCOVER_EXCLUDE = new Set([
  'node_modules', '__pycache__', '.git', '.venv', 'venv', 'dist', 'build',
  '.cache', '.next', '.nuxt', 'target', 'coverage', '.pytest_cache',
  'tests', 'static', '.omc', '.omx',
]);

function t(args) {
  const r = spawnSync('tmux', args, { encoding: 'utf8' });
  return r.status === 0 ? (r.stdout || '').trimEnd() : '';
}
const SPINNER = ['⠋','⠙','⠹','⠸','⠼','⠴','⠦','⠧','⠇','⠏'];
let __frame = 0;

// Single-glyph status badge, always 1 cell, sits left of the project
// name. Mapping the user signed off on:
//   running → animated spinner (alive)
//   done    → ✓ (just finished, awaiting acknowledgement)
//   idle    → blank (acknowledged / nothing happening)
//   failed  → ✕   (kept so failures don't silently look like done)
//   need-input → ? (kept so blocking prompts are visible)
function icon(s, frame = __frame) {
  if (s === 'done')        return '\x1b[1;32m✓\x1b[0m';
  if (s === 'failed')      return '\x1b[1;31m✕\x1b[0m';
  if (s === 'need-input')  return '\x1b[1;33m?\x1b[0m';
  if (s === 'running')     return '\x1b[1;36m' + SPINNER[frame % SPINNER.length] + '\x1b[0m';
  return ' ';
}

// Row chrome stays minimal: just a reverse highlight on the active
// window so the user can locate where they are. Status differentiation
// lives entirely in icon() above — no whole-row color blocks (those
// were "eye-strain loud" and shoved layout when status changed).
function rowStyle(s, active) {
  if (active) return { open: '\x1b[7m', close: '\x1b[0m', loud: false };
  return { open: '', close: '', loud: false };
}
function termWidth() { return process.stdout.columns || 26; }
const ANSI_RE = /^\x1b\[[0-9;]*m/;
// Terminal display width of a single code point. A clickmap row maps a
// logical line to an action, while tmux reports the click's *visual* row.
// They only stay 1:1 while every rendered line fits within the pane width,
// so width math here must count terminal cells — not UTF-16 code units.
// East-Asian wide / fullwidth glyphs and most emoji occupy two cells;
// combining marks and variation selectors occupy none. Measuring them with
// String#length under-counts, the line soft-wraps, and every clickmap row
// below the wrap shifts up by one (issue #14).
function charWidth(cp) {
  if (cp === 0x200b ||
      (cp >= 0x0300 && cp <= 0x036f) ||   // combining diacritical marks
      (cp >= 0x200c && cp <= 0x200f) ||   // zero-width joiners / marks
      (cp >= 0xfe00 && cp <= 0xfe0f)) {   // variation selectors
    return 0;
  }
  if (cp >= 0x1100 && (
      cp <= 0x115f ||                       // Hangul Jamo
      cp === 0x2329 || cp === 0x232a ||
      (cp >= 0x2e80 && cp <= 0x303e) ||     // CJK radicals .. symbols
      (cp >= 0x3041 && cp <= 0x33ff) ||     // Hiragana .. CJK compat
      (cp >= 0x3400 && cp <= 0x4dbf) ||     // CJK Ext A
      (cp >= 0x4e00 && cp <= 0x9fff) ||     // CJK Unified
      (cp >= 0xa000 && cp <= 0xa4cf) ||     // Yi
      (cp >= 0xac00 && cp <= 0xd7a3) ||     // Hangul Syllables
      (cp >= 0xf900 && cp <= 0xfaff) ||     // CJK compat ideographs
      (cp >= 0xfe10 && cp <= 0xfe19) ||     // vertical forms
      (cp >= 0xfe30 && cp <= 0xfe6f) ||     // CJK compat forms
      (cp >= 0xff00 && cp <= 0xff60) ||     // Fullwidth forms
      (cp >= 0xffe0 && cp <= 0xffe6) ||     // Fullwidth signs
      (cp >= 0x1f300 && cp <= 0x1faff) ||   // emoji / pictographs
      (cp >= 0x20000 && cp <= 0x3fffd))) {  // CJK Ext B+
    return 2;
  }
  return 1;
}
function visLen(s) {
  let width = 0;
  for (let i = 0; i < s.length; ) {
    if (s[i] === '\x1b') {
      const m = s.slice(i).match(ANSI_RE);
      if (m) { i += m[0].length; continue; }
    }
    const cp = s.codePointAt(i);
    width += charWidth(cp);
    i += cp > 0xffff ? 2 : 1;
  }
  return width;
}
function pad(text, w) {
  const v = visLen(text);
  if (v > w) {
    let cut = '', width = 0, i = 0;
    while (i < text.length) {
      if (text[i] === '\x1b') {
        const m = text.slice(i).match(ANSI_RE);
        if (m) { cut += m[0]; i += m[0].length; continue; }
      }
      const cp = text.codePointAt(i);
      const cw = charWidth(cp);
      if (width + cw > w - 1) break;   // reserve one cell for the ellipsis
      cut += String.fromCodePoint(cp);
      width += cw;
      i += cp > 0xffff ? 2 : 1;
    }
    return cut + '…\x1b[0m';
  }
  return text + ' '.repeat(w - v);
}

function loadRegistry() {
  try { return (JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8')).projects || []); }
  catch { return []; }
}

function scanSubfolders() {
  const found = []; const seen = new Set();
  for (const root of SCAN_ROOTS) {
    let entries;
    try { entries = fs.readdirSync(root); } catch { continue; }
    for (const name of entries) {
      if (name.startsWith('.')) continue;
      if (DISCOVER_EXCLUDE.has(name)) continue;
      if (seen.has(name)) continue;
      const dir = path.join(root, name);
      let st; try { st = fs.statSync(dir); } catch { continue; }
      if (!st.isDirectory()) continue;
      seen.add(name);
      found.push({ name, mtime: st.mtimeMs });
    }
  }
  found.sort((a, b) => b.mtime - a.mtime);
  return found;
}

function persistOpen(rows) {
  const open = rows.map(r => (r.p || r.n || '').replace(/^[✓✕?…! ]+\s*/, '')).filter(Boolean);
  try {
    let cur = {};
    if (fs.existsSync(STATE_PATH)) cur = JSON.parse(fs.readFileSync(STATE_PATH, 'utf8'));
    const same = JSON.stringify(cur.open || []) === JSON.stringify(open);
    if (!same) {
      cur.open = open;
      writeAtomic(STATE_PATH, JSON.stringify(cur, null, 2) + '\n');
    }
  } catch {}
}

function parseRows(out) {
  return out
    ? out.split('\n').filter(Boolean).map(l => {
      const [i, n, a, s, p, m, statusAt] = l.split('\t');
      const row = { i, n, a: a === '1', s, p: p || n, m };
      if (statusAt) row.statusAt = statusAt;
      return row;
    })
    : [];
}

const VALID_STATUSES = new Set(['idle', 'running', 'done', 'failed', 'need-input']);
const RUNNING_STALE_MS = 45_000;

function normalizeStatus(status, statusAt, now = Date.now()) {
  const s = String(status || 'idle').trim() || 'idle';
  if (!VALID_STATUSES.has(s)) return 'idle';
  if (s !== 'running') return s;

  const at = Number(statusAt);
  // Older sessions did not stamp running transitions. Treat unstamped
  // "running" as stale so a leftover tmux option cannot keep every
  // sidebar in the fast spinner repaint loop forever.
  if (!Number.isFinite(at) || at <= 0) return 'idle';
  if (now - at > RUNNING_STALE_MS) return 'idle';
  return 'running';
}

function normalizeRows(rows, now = Date.now()) {
  return rows.map(r => ({ ...r, s: normalizeStatus(r.s, r.statusAt, now) }));
}

function buildSidebarFrame({ rows, registry, discover, width, frame = __frame }) {
  const w = width || 26;
  // Keep every non-clickable chrome line to a single visual terminal row.
  // If the sidebar is briefly narrower than its configured width (tmux can
  // resize panes proportionally before our self-correction runs), an
  // unconstrained header can soft-wrap and push the visible project rows down
  // while the clickmap still contains the unwrapped row numbers. That makes a
  // click land on the project above the one the user sees. Render chrome at
  // w-1 cells, matching the project rows, so terminal autowrap never shifts
  // click targets.
  const lineW = Math.max(1, w - 1);
  const rowTextW = Math.max(1, w - 3);
  const openNames = new Set(rows.map(r => (r.p || r.n).replace(/^[✓✕?…! ]+\s*/, '')));
  const closed = registry.filter(p => !openNames.has(p.name));
  const registryNames = new Set(registry.map(p => p.name));
  const visibleDiscover = discover
    .filter(p => !openNames.has(p.name) && !registryNames.has(p.name))
    .slice(0, DISCOVER_LIMIT);

  const lines = [];
  lines.push(pad('\x1b[1;38;5;46m nmux-linux\x1b[0m \x1b[2m· projects\x1b[0m', lineW));
  lines.push('\x1b[2m' + '─'.repeat(Math.min(lineW, 30)) + '\x1b[0m');

  // Each entry: row<TAB>action<TAB>arg<TAB>colMin
  const map = [];
  let row = 2;
  const closeColMin = Math.max(0, w - 3);  // last 3 cols reserved for ×

  // -------- open windows --------
  for (const r of rows) {
    const name = (r.p || r.n).replace(/^[✓✕?…! ]+\s*/, '');
    const style = rowStyle(r.s, r.a);
    const arrow = r.a ? '▸' : ' ';
    const idxs = String(r.i).padStart(2);
    const ic = icon(r.s, frame);
    if (style.loud) {
      // Whole-row colored block — name + status + close button all on the
      // background color. Stays loud until the user visits the window
      // (after-select-window → nmux-linux clear-status resets it).
      const inner = `${arrow}${idxs} ${ic} ${name}`;
      const padded = pad(inner, rowTextW);
      // Render close × in the same row block but with explicit fg/bg
      // so it stays readable on the colored background.
      lines.push(style.open + padded + ' ×' + style.close);
    } else {
      const left = `${style.open}${arrow}${idxs} ${ic} ${name}${style.close}`;
      const padded = pad(left, rowTextW);
      const closeMark = r.a ? ' \x1b[1;31m×\x1b[0m' : ' \x1b[2;31m×\x1b[0m';
      lines.push(padded + closeMark);
    }
    map.push(`${row}\tswitch\t${r.i}\t0`);
    map.push(`${row}\tclose\t${r.i}\t${closeColMin}`);
    row++;
    // Intentionally no message line: per-row second line was the source
    // of layout shifts whenever a notify message arrived (e.g. bell ->
    // "bell" text pushing the rest of the sidebar down by 1). State
    // lives in the icon now; the message is dropped from the visual.
  }

  // spacer
  lines.push(''); row++;

  // -------- closed registered projects (reopen) --------
  if (closed.length) {
    lines.push(pad('\x1b[2m closed (click to reopen)\x1b[0m', w - 1));
    row++;
    // limit to first 12 to avoid overwhelming sidebar
    for (const p of closed.slice(0, 20)) {
      lines.push(pad(`\x1b[37m   ${p.name}\x1b[0m`, w - 1));
      map.push(`${row}\treopen\t${p.name}\t0`);
      row++;
    }
    lines.push(''); row++;
  }

  // -------- discoverable subfolders (not yet a project) --------
  if (visibleDiscover.length) {
    lines.push(pad('\x1b[2m new (click to start)\x1b[0m', w - 1));
    row++;
    for (const p of visibleDiscover) {
      lines.push(pad(`\x1b[36m   ${p.name}\x1b[0m`, w - 1));
      map.push(`${row}\treopen\t${p.name}\t0`);
      row++;
    }
    lines.push(''); row++;
  }

  // -------- + new project --------
  lines.push(pad('\x1b[1;36m + new project\x1b[0m', w - 1));
  map.push(`${row}\tadd\t-\t0`);
  row++;

  // -------- ⊗ kill nmux-linux --------
  lines.push(pad('\x1b[1;31m ⊗ kill nmux-linux\x1b[0m', w - 1));
  map.push(`${row}\tkill\t-\t0`);
  row++;

  // hints
  lines.push('');
  lines.push('\x1b[2m' + pad(' click row=switch', lineW) + '\x1b[0m');
  lines.push('\x1b[2m' + pad(' × close window', lineW) + '\x1b[0m');
  lines.push('\x1b[2m' + pad(' M-1..9 keys', lineW) + '\x1b[0m');
  lines.push('\x1b[2m' + pad(' prefix C: new', lineW) + '\x1b[0m');
  lines.push('\x1b[2m' + pad(' prefix X: close', lineW) + '\x1b[0m');

  return {
    body: lines.map(line => pad(line, lineW) + '\x1b[K').join('\n') + '\n\x1b[J',
    clickmap: map.join('\n') + '\n',
  };
}

const SCAN_INTERVAL_MS = 2000;
const STATE_INTERVAL_MS = 1000;
const RESIZE_CHECK_INTERVAL_MS = 1500;
const RESIZE_QUIET_MS = 400;          // wait this long after last width change
                                      // before issuing a self-correcting resize
                                      // (debounce mid-drag flickers)
const SYNC_BEGIN = '\x1b[?2026h';
const SYNC_END = '\x1b[?2026l';
// xterm alternate-screen sequences. Entering "1049" gives us a clean
// per-pane buffer with no scrollback — every re-render only touches the
// alt buffer, so user wheel-scroll / copy-mode shows the current sidebar
// state and nothing else (no stale "closed" project list bleeding through
// from earlier paints). Exiting on shutdown restores the main buffer.
const ALT_SCREEN_ENTER = '\x1b[?1049h';
const ALT_SCREEN_EXIT  = '\x1b[?1049l';
let __registryCache = [];
let __discoverCache = [];
let __nextScanAt = 0;
let __nextStateAt = 0;
let __nextResizeCheckAt = 0;
let __lastWidthSeen = 0;
let __lastWidthChangeAt = 0;
let __lastBody = null;
let __lastClickmap = null;
let __firstPaint = true;
let __rendering = false;
let __renderAgain = false;

function refreshCaches(now, force = false) {
  if (!force && now < __nextScanAt) return;
  __registryCache = loadRegistry();
  __discoverCache = scanSubfolders();
  __nextScanAt = now + SCAN_INTERVAL_MS;
}

// Configured max sidebar width (cells). The actual expected width is
// responsive to the tmux window width so this pane does not fight
// nmux-linux fix-layout when a small monitor/client attaches.
let __configuredWidthCache = null;
function configuredWidth() {
  if (__configuredWidthCache != null) return __configuredWidthCache;
  try {
    const cfg = JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'));
    const w = Number(cfg.sidebarWidth);
    __configuredWidthCache = Number.isFinite(w) && w > 0 ? w : DEFAULT_SIDEBAR_WIDTH;
  } catch { __configuredWidthCache = DEFAULT_SIDEBAR_WIDTH; }
  return __configuredWidthCache;
}

function tmuxWindowWidthForPane(pane) {
  if (!pane) return 0;
  const r = spawnSync('tmux', ['display-message', '-p', '-t', pane, '#{window_width}'], { encoding: 'utf8' });
  if (r.status !== 0) return 0;
  const w = parseInt((r.stdout || '').trim(), 10);
  return Number.isFinite(w) ? w : 0;
}

function expectedWidth() {
  const pane = process.env.TMUX_PANE;
  const winW = tmuxWindowWidthForPane(pane);
  return responsiveSidebarWidth(winW, configuredWidth());
}

// Defense in depth: tmux hooks pin the sidebar width on common events,
// but a manual border-drag with no subsequent event (or a race during
// new-window setup) can leave the sidebar drifted. Once the visible
// width has been stable for RESIZE_QUIET_MS and still differs from the
// configured cell-width, request a one-shot resize-pane back.
function selfCorrectWidth(now) {
  if (now < __nextResizeCheckAt) return;
  __nextResizeCheckAt = now + RESIZE_CHECK_INTERVAL_MS;
  const cur = process.stdout.columns || 0;
  if (!cur) return;
  if (cur !== __lastWidthSeen) {
    __lastWidthSeen = cur;
    __lastWidthChangeAt = now;
    return;
  }
  if (now - __lastWidthChangeAt < RESIZE_QUIET_MS) return;
  const want = expectedWidth();
  // tmux can leave a pane one cell wider/narrower after accounting for
  // borders. Treat ±1 as converged; repeatedly forcing that last cell is the
  // exact resize tug-of-war that shows up as sidebar flicker on small screens.
  if (Math.abs(cur - want) <= 1) return;
  const pane = process.env.TMUX_PANE;
  if (!pane) return;
  spawnSync('tmux', ['resize-pane', '-t', pane, '-x', String(want)], { stdio: 'ignore' });
}

function terminalFrame(body) {
  const clear = __firstPaint ? '\x1b[2J\x1b[H' : '\x1b[H';
  return SYNC_BEGIN + clear + body + SYNC_END;
}

let __anyRunning = false;
function render({ forceScan = false } = {}) {
  if (__rendering) { __renderAgain = true; return; }
  __rendering = true;
  try {
    const now = Date.now();
    refreshCaches(now, forceScan);
    selfCorrectWidth(now);
    const w = termWidth();
    const fmt = '#{window_index}\t#{window_name}\t#{window_active}\t#{@nmuxlinux_status}\t#{@nmuxlinux_project}\t#{@nmuxlinux_message}\t#{@nmuxlinux_status_at}';
    const rows = normalizeRows(parseRows(t(['list-windows', '-t', SESSION, '-F', fmt])), now);
    __anyRunning = rows.some(r => r.s === 'running');
    const { body, clickmap } = buildSidebarFrame({
      rows,
      registry: __registryCache,
      discover: __discoverCache,
      width: w,
      frame: __frame,
    });

    if (clickmap !== __lastClickmap) {
      try { writeAtomic(CLICKMAP_PATH, clickmap); } catch {}
      __lastClickmap = clickmap;
    }
    if (body !== __lastBody) {
      process.stdout.write(terminalFrame(body));
      __firstPaint = false;
      __lastBody = body;
    }
    if (forceScan || now >= __nextStateAt) {
      persistOpen(rows);
      __nextStateAt = now + STATE_INTERVAL_MS;
    }
  } finally {
    __rendering = false;
  }
  if (__renderAgain) {
    __renderAgain = false;
    render({ forceScan });
  }
}

const TICK_FAST_MS = 200;     // while a spinner needs to animate
const TICK_SLOW_MS = 1000;    // idle — every sidebar polls list-windows
                              // each tick, so N sidebars × fast = N×5 IPCs/sec.
                              // Slowing the idle case cuts tmux-server load
                              // ~5× without affecting interactive feel.
function start() {
  // Scrollback containment for the sidebar pane — but NOT via
  // `set-option -p history-limit 0`. In some tmux versions that
  // setting bleeds globally (server-wide default), and any pane
  // created after the sidebar boots inherits limit=0, killing wheel-
  // scroll on the user's main / right-top / right-bot panes. Instead
  // we rely on:
  //   • alt-screen mode (entered just below) so the live frame uses
  //     the alt buffer
  //   • clear-history on every render of this pane (cheap; called from
  //     render()), keeping the alt buffer scrollback empty without
  //     touching tmux's global history-limit
  if (process.env.TMUX_PANE) {
    spawnSync('tmux', ['clear-history', '-t', process.env.TMUX_PANE],
              { stdio: 'ignore' });
  }
  // Switch the pane to its alternate screen buffer up-front so the
  // initial bash prompt / any pre-sidebar output stays behind in the
  // main buffer and never bleeds into our render. Every subsequent
  // terminalFrame() targets the alt buffer; on exit we drop back so
  // the pane closes cleanly.
  process.stdout.write(ALT_SCREEN_ENTER);
  render({ forceScan: true });
  let __timer = null;
  function schedule() {
    const delay = __anyRunning ? TICK_FAST_MS : TICK_SLOW_MS;
    __timer = setTimeout(() => {
      __frame = (__frame + 1) % SPINNER.length;
      render();
      schedule();
    }, delay);
  }
  schedule();

  // Allow the nmux-linux command to nudge us for an instant repaint.
  // Cancel the pending slow tick so the SIGUSR1 repaint isn't followed
  // by a stale-content wait.
  process.on('SIGUSR1', () => {
    if (__timer) clearTimeout(__timer);
    render({ forceScan: true });
    schedule();
  });

  // Best-effort cleanup of the per-pane clickmap on exit so stale files
  // don't accumulate in CLICKMAP_DIR. Also drop the alternate screen so
  // the pane reverts to whatever was in the main buffer (typically
  // empty if the pane is about to die anyway).
  function __exitCleanup() {
    try { process.stdout.write(ALT_SCREEN_EXIT); } catch {}
    try { fs.unlinkSync(CLICKMAP_PATH); } catch {}
  }
  process.on('SIGTERM', () => { if (__timer) clearTimeout(__timer); __exitCleanup(); process.exit(0); });
  process.on('SIGINT',  () => { if (__timer) clearTimeout(__timer); __exitCleanup(); process.exit(0); });
  process.on('exit',    __exitCleanup);
}

if (require.main === module) start();
else module.exports = {
  buildSidebarFrame,
  icon,
  normalizeRows,
  normalizeStatus,
  pad,
  parseRows,
  responsiveSidebarWidth,
  RUNNING_STALE_MS,
  SPINNER,
  terminalFrame,
};
