#!/usr/bin/env node
// nmux-linux — tmux addon: project sidebar with mouse navigation,
// per-project window, persistent open-set, agent-finish notifier.
// Layout per window: sidebar (left) | main shell | right-top / right-bot.

const { spawnSync, spawn } = require('child_process');
const fs = require('fs');
const path = require('path');
const os = require('os');

const HOME = os.homedir();
const CONFIG_DIR = path.join(HOME, '.config', 'nmux-linux');
const CONFIG_PATH = path.join(CONFIG_DIR, 'projects.json');
const STATE_PATH = path.join(CONFIG_DIR, 'state.json');
const CLICKMAP_DIR = path.join(CONFIG_DIR, 'clickmaps');  // one file per sidebar pane
const SESSION = 'nmux-linux';
const SIDEBAR_WIDTH = 26;
const SIDEBAR_MIN_WIDTH = 16;
const SIDEBAR_COMPACT_WIDTH = 20;
const RIGHT_MIN_WIDTH = 16;
const RIGHT_DEFAULT_MIN_WIDTH = 24;
const SUB_MIN_WIDTH = 40;
const SCAN_ROOTS = [path.join(HOME, 'projects'), path.join(HOME, 'projects', 'private')];

function clampInt(n, min, max) {
  const v = Math.floor(Number(n));
  const lo = Math.floor(Number(min));
  const hi = Math.floor(Number(max));
  if (!Number.isFinite(v)) return lo;
  return Math.max(lo, Math.min(hi, v));
}

// Keep the sidebar readable on large terminals but stop forcing 26 cells
// into narrow clients. This same breakpoint logic is duplicated in the
// sidebar helper so its self-correction does not fight fix-layout during
// monitor/window-size changes.
function responsiveSidebarWidth(winW, configured = SIDEBAR_WIDTH) {
  const max = clampInt(configured || SIDEBAR_WIDTH, 12, 40);
  const w = Number(winW);
  if (!Number.isFinite(w) || w <= 0) return max;
  if (w < 72) return Math.min(max, SIDEBAR_MIN_WIDTH);
  if (w < 104) return Math.min(max, SIDEBAR_COMPACT_WIDTH);
  return max;
}

function computeResponsiveLayout(winW, winH, configuredSidebar = SIDEBAR_WIDTH, opts = {}) {
  const total = (Number.isFinite(Number(winW)) && Number(winW) > 0)
    ? Math.floor(Number(winW))
    : (Number(configuredSidebar) || SIDEBAR_WIDTH) + 140;
  const sidebarWidth = responsiveSidebarWidth(total, configuredSidebar);
  const hasRight = opts.hasRight !== false;
  const hasSub = !!opts.hasSub;
  const wantSub = !!opts.wantSub || hasSub;
  const minMain = total < 80 ? 22 : (total < 120 ? 36 : 50);
  const minRight = total < 80 ? RIGHT_MIN_WIDTH : (total < 112 ? 20 : RIGHT_DEFAULT_MIN_WIDTH);
  const maxRight = total < 104 ? 24 : (total < 160 ? 32 : 48);
  // tmux pane borders consume a few cells between columns. Keeping a small
  // reserve prevents a mathematically-full plan from causing tmux to steal
  // cells from the sidebar/main during resize.
  const available = Math.max(1, total - sidebarWidth - 3);

  let rightWidth = hasRight ? clampInt(Math.floor(total / 6), minRight, maxRight) : 0;
  if (hasRight && available - rightWidth < minMain) {
    rightWidth = Math.max(0, available - minMain);
  }

  const canFullSub = wantSub
    && isWideAspect(total, Number(winH))
    && available - rightWidth >= minMain + SUB_MIN_WIDTH;
  let subWidth = 0;
  if (canFullSub) {
    subWidth = clampInt(Math.floor(total / 3), SUB_MIN_WIDTH, Math.floor(total * 0.34));
  } else if (hasSub) {
    // Preserve an existing auxiliary pane when moving from a large monitor to
    // a small one, but collapse it to a harmless sliver so main+status remain
    // usable. We do not kill panes from an automatic resize hook.
    subWidth = Math.min(12, Math.max(0, available - rightWidth - minMain));
    if (subWidth < 6) subWidth = 0;
  }

  if (available - rightWidth - subWidth < minMain) {
    subWidth = Math.max(0, available - rightWidth - minMain);
  }
  if (available - rightWidth - subWidth < minMain) {
    rightWidth = Math.max(0, available - subWidth - minMain);
  }
  if (hasRight) rightWidth = Math.max(1, rightWidth);
  const mainWidth = Math.max(1, available - rightWidth - subWidth);
  const mode = total < 104 ? 'small' : (canFullSub ? 'wide' : 'medium');
  return { mode, total, sidebarWidth, mainWidth, rightWidth, subWidth, canFullSub };
}

// Resolve own install location from argv[1] so a non-default --prefix
// (e.g. /opt/nmux-linux/bin/nmux-linux) still spawns the right helper.
function __resolveSelfDir() {
  try { return path.dirname(fs.realpathSync(process.argv[1])); }
  catch { return path.join(HOME, '.local', 'bin'); }
}
const NMUX_BIN_DIR = __resolveSelfDir();
const NMUX_BIN = path.join(NMUX_BIN_DIR, 'nmux-linux');
const SIDEBAR_HELPER = path.join(NMUX_BIN_DIR, 'nmux-linux-sidebar');

// Atomic JSON / text writes. Writes a sibling tmp then renames into place.
function writeAtomic(filePath, content) {
  const dir = path.dirname(filePath);
  fs.mkdirSync(dir, { recursive: true });
  const tmp = path.join(dir, '.' + path.basename(filePath) + '.tmp.' + process.pid + '.' + Date.now());
  fs.writeFileSync(tmp, content);
  fs.renameSync(tmp, filePath);
}

// Shell-quote — single quote, escape embedded single quotes.
function shQuote(s) { return `'${String(s).replace(/'/g, `'\\''`)}'`; }

const HELP = `nmux-linux — tmux addon

Usage:
  nmux-linux                       launch+attach (default)
  nmux-linux launch                idem
  nmux-linux init [--force]        rescan and write ${CONFIG_PATH}
  nmux-linux apply [--replace]     rebuild session from open-set
  nmux-linux refresh               reapply bindings/options to a running session
  nmux-linux refresh-sidebars      respawn sidebar panes to pick up new code
  nmux-linux status                print session state
  nmux-linux kill                  kill nmux-linux session (state is auto-saved)
  nmux-linux click <y> [x]         internal: handle sidebar mouse click
  nmux-linux prompt                internal: command-prompt to add/open a project
  nmux-linux confirm-kill          internal: confirm-before kill the nmux-linux session
  nmux-linux open <name|path>      open project as window (auto-add if path)
  nmux-linux close-window <idx>    close window by index (saves state)
  nmux-linux close-current         close current window (saves state)
  nmux-linux relayout              rebuild current window into sidebar | main | right(top/bot)
  nmux-linux fix-layout            re-pin sidebar width across windows (called by hooks)
  nmux-linux clean-omx-hud         remove definite omx HUD panes from nmux-linux
  nmux-linux preview [--external|--cmd] [--focus] <url|command>
                                   show a terminal-native preview in right-top
  nmux-linux webview ...           alias for preview
  nmux-linux disable-omx-hud       patch omx reconcile.js + set NMUX_LINUX_DISABLE_HUD=1
                             so omx stops auto-spawning the bottom HUD pane
  nmux-linux save-state            persist current open-windows
  nmux-linux notify --project N --status done|failed|need-input|running [--message M]
  nmux-linux notify-current --status ...   resolve project from current TMUX pane
  nmux-linux add <name> <path>     append project to registry
  nmux-linux rm <name>             remove project from registry
`;

// ---------- helpers ----------
function tmux(args, opts = {}) {
  const r = spawnSync('tmux', args, { encoding: 'utf8', ...opts });
  if (r.status !== 0 && !opts.allowFail) {
    const err = (r.stderr || '').trim() || `exit ${r.status}`;
    throw new Error(`tmux ${args.join(' ')}: ${err}`);
  }
  return (r.stdout || '').trimEnd();
}
function tmuxOk(args) {
  const r = spawnSync('tmux', args, { encoding: 'utf8' });
  return r.status === 0;
}
function which(bin) {
  const r = spawnSync('which', [bin], { encoding: 'utf8' });
  return r.status === 0 ? r.stdout.trim() : null;
}
function shEsc(s) { return `'${String(s).replace(/'/g, `'\\''`)}'`; }

const RUNNING_STATUS_STALE_MS = 45_000;

function setWindowStatus(target, status, message, opts = {}) {
  tmux(['set-window-option', '-t', target, '@nmuxlinux_status', status], opts);
  if (message !== undefined) {
    tmux(['set-window-option', '-t', target, '@nmuxlinux_message', String(message).slice(0, 120)], opts);
  }
  tmux(['set-window-option', '-t', target, '@nmuxlinux_status_at', String(Date.now())], opts);
}

function runningStatusIsFresh(target) {
  const atStr = tmux(['show-window-options', '-t', target, '-v', '@nmuxlinux_status_at'],
    { allowFail: true }).trim();
  const at = parseInt(atStr, 10);
  return Number.isFinite(at) && at > 0 && Date.now() - at <= RUNNING_STATUS_STALE_MS;
}

// ---------- config / state ----------
function ensureConfigDir() { fs.mkdirSync(CONFIG_DIR, { recursive: true }); }
function loadConfig() {
  if (!fs.existsSync(CONFIG_PATH)) return null;
  try { return migrateConfig(JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'))); }
  catch (e) { throw new Error(`config parse error: ${e.message}`); }
}
function saveConfig(cfg) {
  ensureConfigDir();
  writeAtomic(CONFIG_PATH, JSON.stringify(cfg, null, 2) + '\n');
}
function migrateConfig(cfg) {
  cfg.projects = (cfg.projects || []).map(p => {
    delete p.panes; delete p.main; delete p.sub; delete p.exec;
    if (typeof p.notifyOnFinish !== 'boolean') p.notifyOnFinish = true;
    return p;
  });
  cfg.sidebarWidth = Number(cfg.sidebarWidth) || SIDEBAR_WIDTH;
  delete cfg.progressWidth;
  cfg.session = cfg.session || SESSION;
  cfg.statusPosition = cfg.statusPosition || 'top';
  return cfg;
}

function loadState() {
  try { return JSON.parse(fs.readFileSync(STATE_PATH, 'utf8')); }
  catch { return { open: [] }; }
}
function saveState(s) {
  ensureConfigDir();
  writeAtomic(STATE_PATH, JSON.stringify(s, null, 2) + '\n');
}

function scanProjects() {
  const found = []; const seen = new Set();
  for (const root of SCAN_ROOTS) {
    if (!fs.existsSync(root)) continue;
    for (const name of fs.readdirSync(root)) {
      if (name.startsWith('.')) continue;
      const dir = path.join(root, name);
      let st; try { st = fs.statSync(dir); } catch { continue; }
      if (!st.isDirectory() || !fs.existsSync(path.join(dir, '.git'))) continue;
      if (seen.has(name)) continue; seen.add(name);
      found.push({ name, cwd: dir, mtime: st.mtimeMs });
    }
  }
  found.sort((a, b) => b.mtime - a.mtime);
  return found.map(({ name, cwd }) => ({ name, cwd }));
}
function defaultProject(name, cwd) {
  return { name, cwd, notifyOnFinish: true };
}
function initConfig({ force = false } = {}) {
  ensureConfigDir();
  if (fs.existsSync(CONFIG_PATH) && !force) return loadConfig();
  const cfg = {
    session: SESSION,
    sidebarWidth: SIDEBAR_WIDTH,
    statusPosition: 'top',
    projects: scanProjects().slice(0, 24).map(p => defaultProject(p.name, p.cwd))
  };
  saveConfig(cfg);
  return cfg;
}

// ---------- session bindings + per-window option scrub ----------
function sessionExists(name) { return tmuxOk(['has-session', '-t', name]); }

function listWindowIndices(session) {
  const out = tmux(['list-windows', '-t', session, '-F', '#{window_index}'], { allowFail: true });
  return out.split('\n').filter(Boolean);
}

function scrubWindowStatus(session) {
  // Strip the top window-status "tabs" per window; sidebar replaces them.
  // Keep pane-border-status='top' so non-sidebar panes can still show their
  // titles (main = project, right-top, right-bot). The conditional
  // pane-border-format below renders an empty bar specifically for the
  // sidebar pane only.
  // Some agents emit kitty-graphics / base64 blobs that land in pane_title and then
  // render as a wall of garbage across this border on every redraw (the
  // user sees "weird characters in a row" when scrolling or clicking the agent
  // pane). Guard the title: when it matches a kitty-graphics APC payload shape
  // (`G<key>=...;...`, e.g. `Gm=0;<base64>`) fall back to the trusted project
  // name kept in @nmuxlinux_project instead of echoing the raw escape bytes.
  const safeTitle = '#{?#{m:G?=*;*,#{pane_title}},#{@nmuxlinux_project},#{pane_title}}';
  const sidebarFmt = ' #[bold]#{?pane_active,#[fg=colour46],#[fg=colour244]}'
    + `#{?#{==:#{pane_title},nmux-linux-sidebar}, ,#P · ${safeTitle}}#[default] `;
  for (const idx of listWindowIndices(session)) {
    const target = `${session}:${idx}`;
    tmux(['set-window-option', '-t', target, 'window-status-format', ' '], { allowFail: true });
    tmux(['set-window-option', '-t', target, 'window-status-current-format', ' '], { allowFail: true });
    tmux(['set-window-option', '-t', target, 'window-status-separator', ''], { allowFail: true });
    tmux(['set-window-option', '-t', target, 'pane-border-status', 'top'], { allowFail: true });
    tmux(['set-window-option', '-t', target, 'pane-border-format', sidebarFmt], { allowFail: true });
  }
}

function applyTmuxLines(lines) {
  // Apply each line via source-file but isolate failures so a single
  // bad line doesn't break the whole bindings installation.
  // Use a private mkdtemp directory so /tmp/nmux-linux-bindings-* is not
  // a fixed/predictable filename (avoids symlink-attack class on shared hosts).
  const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'nmux-linux-'));
  const tmpFile = path.join(tmpDir, 'bindings.tmux');
  try {
    for (const line of lines) {
      try {
        fs.writeFileSync(tmpFile, line + '\n');
        tmux(['source-file', tmpFile]);
      } catch (e) {
        console.error(`[nmux-linux] skip line: ${line}\n  reason: ${(e.message || e).slice(0, 200)}`);
      }
    }
  } finally {
    try { fs.unlinkSync(tmpFile); } catch {}
    try { fs.rmdirSync(tmpDir); } catch {}
  }
}

function installBindings(session) {
  const lines = [
    // Session-level
    `set-option -t ${session} status off`,
    `set-option -t ${session} base-index 1`,
    `set-option -t ${session} mouse on`,

    // Keep per-pane border titles, but hide the one above the sidebar pane.
    // (Per-window pane-border-format set in scrubWindowStatus.)
    `set-option -t ${session} pane-border-status top`,

    // Sidebar already labels actions/projects, so hide tmux's global
    // status line entirely. The old static hint ("click sidebar · prefix C…")
    // looked like an unexplained top toolbar and its status area could still
    // receive mouse focus/clicks.
    `set-option -t ${session} status-left ""`,
    `set-option -t ${session} status-left-length 0`,
    `set-option -t ${session} status-right ""`,
    `set-option -t ${session} status-right-length 0`,
    `set-option -t ${session} status-justify left`,

    // Tell omx to skip auto-spawning the HUD pane below — nmux-linux already owns
    // the pane layout. Requires the matching env-check patch in
    // ~/.local/lib/node_modules/oh-my-codex/dist/hud/reconcile.js.
    `set-environment -t ${session} NMUX_LINUX_DISABLE_HUD 1`,

    // Mouse on sidebar pane → nmux-linux click <y> <x>.
    // Bound to MouseUp1Pane (not MouseDown1Pane) so drag-selection still
    // works: MouseDrag1Pane fires copy-mode -M, copy-mode captures the
    // rest of the gesture, and MouseUp1Pane in the root table is bypassed.
    // A bare tap (down+up no drag) keeps reaching us, fires the click
    // handler. MouseDown1Pane is explicitly re-asserted to tmux's stock
    // `select-pane -t=` so a refresh after the binding moved from
    // MouseDown→MouseUp doesn't leave behind a stale ours-only mapping.
    //
    // `-b` is critical: without it, run-shell blocks the entire tmux
    // server for the click handler's lifetime (~30-100ms). Backgrounded
    // hooks (fix-layout, clear-status) plus user input pile up behind
    // each click, so a burst of clicks feels "stuck" for half a second
    // and then catches up all at once. Backgrounding makes the binding
    // fire-and-forget — the user's next click is processed immediately.
    `bind-key -T root MouseDown1Pane select-pane -t=`,
    // 3-way click routing dispatched via node — nested tmux
    // if-shell with double quotes inside its branch strings can't
    // be parsed by tmux (treated as "too many arguments"), so we
    // do the routing in JS. #{pane_title} is NOT passed through the
    // shell: an app can set its title to arbitrary bytes (OSC 0/2),
    // and a quote/`;` in the title would break the single-quoted
    // run-shell string and execute the garbage as a command. The
    // title is resolved safely inside node from the trusted pane id.
    `bind-key -T root MouseUp1Pane run-shell -b '${NMUX_BIN} mouseup #{pane_id} #{session_name} #{mouse_y} #{mouse_x}'`,

    // Wheel routing: a tiny node helper does the 3-way dispatch
    // (sidebar swallow / right-top → daemon / else → copy-mode).
    // Nested tmux if-shell quoting was unmanageable across two
    // levels, so we move the routing out of the tmux config.
    `bind-key -T root WheelUpPane run-shell -b '${NMUX_BIN} wheel up #{pane_id} #{session_name} #{pane_in_mode} #{mouse_any_flag}'`,
    `bind-key -T root WheelDownPane run-shell -b '${NMUX_BIN} wheel down #{pane_id} #{session_name} #{pane_in_mode} #{mouse_any_flag}'`,

    // Double-click on a non-sidebar nmux-linux pane fires only the URL
    // launcher (background): capture pane wrap-joined, find the URL on
    // the clicked visual row (incl. wrapped halves), xdg-open + wl-copy.
    // We deliberately do NOT chain the stock copy-mode -H ; select-word
    // ; run-shell -d 0.3 ; copy-pipe-and-cancel sequence — that 0.3s
    // window leaves the pane in copy-mode-vi where any subsequent
    // keystroke (f, ;, t, ,, /, ?) gets interpreted as a vi-jump
    // command, popping the "(jump forward)" prompt and absorbing all
    // following clicks until cancelled. Word-copy via double-click is
    // sacrificed; drag-select still works through the wlcopy --join
    // helper for any text-grab need.
    `bind-key -T root DoubleClick1Pane select-pane -t= \\; if-shell -F "#{&&:#{==:#{session_name},${session}},#{!=:#{pane_title},nmux-linux-sidebar}}" "run-shell -b '${NMUX_BIN} click-url #{pane_id} #{mouse_y}'" ""`,

    // Prefix
    `bind-key -T prefix C run-shell "${NMUX_BIN} prompt"`,
    `bind-key -T prefix X run-shell "${NMUX_BIN} close-current"`,

    // Bell-driven notify intentionally disabled: a stray bell from any
    // process inside a project window would flip status to done + push a
    // "bell" message line, shifting the sidebar layout. Real completion
    // signals come from the Claude/omx hooks instead.
    `set-window-option -g monitor-bell off`,

    // Sidebar fix-up: tmux scales panes proportionally on resize/attach,
    // so the sidebar stretches when a wider client attaches. Pin it back.
    // We deliberately do NOT hook after-resize-pane / after-kill-pane:
    // those events fire FROM fix-layout's own resize-pane calls, which
    // produces an unbounded hook-storm. Manual border drags are caught
    // by the sidebar process's own width self-correction in
    // bin/nmux-linux-sidebar (selfCorrectWidth) instead.
    `set-hook -g client-attached "run-shell -b 'NMUX_LINUX_HOOK_SESSION=#{session_name} ${NMUX_BIN} fix-layout >/dev/null 2>&1 || true'"`,
    `set-hook -g client-resized "run-shell -b 'NMUX_LINUX_HOOK_SESSION=#{session_name} ${NMUX_BIN} fix-layout >/dev/null 2>&1 || true'"`,
    `set-hook -g window-resized "run-shell -b 'NMUX_LINUX_HOOK_SESSION=#{session_name} ${NMUX_BIN} fix-layout >/dev/null 2>&1 || true'"`,
    // Avoid after-split-window for fix-layout: layout repair itself uses
    // split-window, so this hook can recurse and create duplicate status panes.
    // Unset the old global hook installed by earlier nmux-linux versions.
    `set-hook -gu after-split-window`,

    // Visiting a window clears its bell/done indicator (the ✓ in the sidebar).
    `set-hook -g after-select-window "run-shell -b '${NMUX_BIN} clear-status --project \\"#{@nmuxlinux_project}\\" >/dev/null 2>&1 || true'"`,
    `set-hook -g session-window-changed "run-shell -b '${NMUX_BIN} clear-status --project \\"#{@nmuxlinux_project}\\" >/dev/null 2>&1 || true'"`,
  ];
  applyTmuxLines(lines);
  scrubWindowStatus(session);
}

function nextWindowIndex(session) {
  const out = tmux(['list-windows', '-t', session, '-F', '#{window_index}'], { allowFail: true });
  const idxs = out.split('\n').map(s => parseInt(s, 10)).filter(Number.isFinite);
  return idxs.length ? Math.max(...idxs) + 1 : 1;
}

function buildWindow(cfg, project, isFirst) {
  const cwd = project.cwd;
  const shell = process.env.SHELL || '/bin/bash';

  let idx;
  if (isFirst) {
    tmux(['new-session', '-d', '-s', cfg.session, '-n', project.name, '-c', cwd, shell]);
    installBindings(cfg.session);
    // The session has exactly one window now — read its index back instead
    // of trusting display-message, which under `-t SESSION` (no window
    // specifier) resolves to whatever tmux considers the first matching
    // window of the session. After the post-build move-window -r in
    // applySession this becomes the canonical first window.
    const wins = tmux(['list-windows', '-t', cfg.session, '-F', '#{window_index}'], { allowFail: true });
    idx = (wins.split('\n')[0] || '1').trim() || '1';
  } else {
    // Pin the index explicitly so `set-window-option -t SESSION:idx ...`
    // for the brand-new window can never collide with an existing one.
    idx = String(nextWindowIndex(cfg.session));
    tmux(['new-window', '-t', `${cfg.session}:${idx}`, '-n', project.name, '-c', cwd, shell]);
  }
  const target = `${cfg.session}:${idx}`;
  tmux(['set-window-option', '-t', target, '@nmuxlinux_project', project.name]);
  setWindowStatus(target, 'idle', '');
  // strip tabs on this window
  tmux(['set-window-option', '-t', target, 'window-status-format', ' '], { allowFail: true });
  tmux(['set-window-option', '-t', target, 'window-status-current-format', ' '], { allowFail: true });
  tmux(['set-window-option', '-t', target, 'window-status-separator', ''], { allowFail: true });
  tmux(['set-window-option', '-t', target, 'pane-border-status', 'top'], { allowFail: true });

  buildLayout(cfg, target, project, cwd, shell);
}

function buildLayout(cfg, target, project, cwd, shell) {
  // Title the active pane (main shell created by new-window/new-session).
  tmux(['select-pane', '-t', target, '-T', paneTitleFor(project.name, 'main')], { allowFail: true });

  const winInfo = tmux(['display-message', '-p', '-t', target,
    '#{window_width}\t#{window_height}'], { allowFail: true }).trim();
  const [wwStr, whStr] = winInfo.split('\t');
  const winW = parseInt(wwStr, 10);
  const winH = parseInt(whStr, 10);
  const plan = computeResponsiveLayout(winW, winH, cfg.sidebarWidth || SIDEBAR_WIDTH, {
    hasRight: true,
    wantSub: isWideAspect(winW, winH),
  });

  // Split LEFT for sidebar (fixed cells).
  tmux(['split-window', '-t', target, '-b', '-h', '-l', String(plan.sidebarWidth),
        '-c', cwd,
        `bash -lc ${shEsc(`NMUX_LINUX_SESSION=${cfg.session} exec ${SIDEBAR_HELPER}`)}`], { allowFail: true });
  tmux(['select-pane', '-t', target, '-T', 'nmux-linux-sidebar'], { allowFail: true });

  // Back to main.
  tmux(['select-pane', '-t', target, '-R'], { allowFail: true });

  // Layout (left → right): sidebar | main | status/bash column [| sub]
  //   sub is only created on ultrawide monitors; 16:9 screens aren't
  //   wide enough for four equal columns and the user prefers to
  //   reclaim that space for main.
  //   wide  : main = W/2 - sw,        status = W/6, sub = W/3
  //   16:9  : main = W - sw - status, status = W/6
  const TITLE_SUB = paneTitleFor(project.name, 'sub');
  const TITLE_STATUS = paneTitleFor(project.name, 'status');
  const TITLE_BASH = paneTitleFor(project.name, 'bash');

  if (plan.subWidth > 0) {
    // Step 1: from main, split → sub at far right.
    tmux(['split-window', '-t', target, '-h', '-l', String(plan.subWidth), '-c', cwd, shell],
      { allowFail: true });
    tmux(['select-pane', '-t', target, '-T', TITLE_SUB], { allowFail: true });
    tmux(['select-pane', '-t', target, '-L'], { allowFail: true });
  }

  // Step 2: from main, split → status pane (status column ends up
  // between main and sub on wide, or at the far right on 16:9).
  tmux(['split-window', '-t', target, '-h', '-l', String(plan.rightWidth), '-c', cwd,
        `bash -lc ${shEsc(`exec ${NMUX_BIN} task-overlay --cwd ${shQuote(cwd)}`)}`],
    { allowFail: true });
  tmux(['select-pane', '-t', target, '-T', TITLE_STATUS], { allowFail: true });

  // Step 3: split status vertically → bash.
  tmux(['split-window', '-t', target, '-v', '-l', '50%', '-c', cwd, shell],
    { allowFail: true });
  tmux(['select-pane', '-t', target, '-T', TITLE_BASH], { allowFail: true });

  // Focus back to main (bash → status up → main left).
  tmux(['select-pane', '-t', target, '-U'], { allowFail: true });
  tmux(['select-pane', '-t', target, '-L'], { allowFail: true });
}

// Aspect detection. Terminal cells are roughly 2× taller than wide,
// so a 16:9 pixel monitor is ~3.5 in cell ratio while a 21:9
// ultrawide is ~4.8 and 32:9 super-ultrawide ~7. Threshold of 4.0
// reliably separates "show 4-column layout" from "fall back to 3
// columns". `width >= 300` is a safety net for huge windows whose
// height we can't trust (some terminals report inflated height).
function isWideAspect(winW, winH) {
  if (!Number.isFinite(winW)) return false;
  if (winW >= 300) return true;
  if (!Number.isFinite(winH) || winH <= 0) return false;
  return (winW / winH) >= 4.0;
}

function relayoutCurrent() {
  if (!process.env.TMUX) { console.error('not inside tmux'); return; }
  const info = tmux(['display-message', '-p', '#{session_name}\t#{window_index}\t#{@nmuxlinux_project}\t#{pane_current_path}'], { allowFail: true });
  const [s, idx, projName, pcwd] = info.split('\t');
  if (s !== SESSION) { console.error('not in nmux-linux session'); return; }
  const target = `${SESSION}:${idx}`;
  const cfg = loadConfig() || initConfig();
  const cwd = (cfg.projects.find(p => p.name === projName) || {}).cwd || pcwd;
  const shell = process.env.SHELL || '/bin/bash';
  // Find the main pane (any pane that's NOT the nmux-linux-sidebar). Prefer one with title === projName.
  const panesOut = tmux(['list-panes', '-t', target, '-F', '#{pane_id}\t#{pane_title}\t#{pane_pid}'], { allowFail: true });
  const all = panesOut.split('\n').filter(Boolean).map(l => {
    const [pid, title, ppid] = l.split('\t');
    return { pid, title, ppid, isSidebar: title === 'nmux-linux-sidebar' || isSidebarPid(ppid) };
  });
  const sidebar = all.find(p => p.isSidebar);
  const candidates = all.filter(p => !p.isSidebar);
  const main = candidates.find(p => p.title === paneTitleFor(projName, 'main'))
            || candidates.find(p => p.title === projName) // legacy plain-name
            || candidates.find(p => paneRoleOf(p.title) === null)
            || candidates[0];
  if (!main) { console.error('no main pane found'); return; }
  // Kill every pane except sidebar and main.
  for (const p of candidates) {
    if (p.pid === main.pid) continue;
    tmux(['kill-pane', '-t', p.pid], { allowFail: true });
  }
  if (!sidebar) {
    // Recreate sidebar on the LEFT
    const winInfo = tmux(['display-message', '-p', '-t', target,
      '#{window_width}\t#{window_height}'], { allowFail: true }).trim();
    const [ww, wh] = winInfo.split('\t').map(n => parseInt(n, 10));
    const plan = computeResponsiveLayout(ww, wh, cfg.sidebarWidth || SIDEBAR_WIDTH, { hasRight: true });
    tmux(['split-window', '-t', main.pid, '-b', '-h', '-l', String(plan.sidebarWidth),
          '-c', cwd,
          `bash -lc ${shEsc(`NMUX_LINUX_SESSION=${cfg.session} exec ${SIDEBAR_HELPER}`)}`], { allowFail: true });
    tmux(['select-pane', '-t', target, '-T', 'nmux-linux-sidebar'], { allowFail: true });
    tmux(['select-pane', '-t', main.pid], { allowFail: true });
  } else {
    // Resize sidebar back to configured width.
    const winInfo = tmux(['display-message', '-p', '-t', target,
      '#{window_width}\t#{window_height}'], { allowFail: true }).trim();
    const [ww, wh] = winInfo.split('\t').map(n => parseInt(n, 10));
    const plan = computeResponsiveLayout(ww, wh, cfg.sidebarWidth || SIDEBAR_WIDTH, { hasRight: true });
    tmux(['resize-pane', '-t', sidebar.pid, '-x', String(plan.sidebarWidth)], { allowFail: true });
  }
  // Mirror buildLayout exactly: sidebar | main | status/bash [| sub]
  tmux(['select-pane', '-t', main.pid, '-T', paneTitleFor(projName, 'main')],
    { allowFail: true });
  tmux(['select-pane', '-t', main.pid], { allowFail: true });
  const winInfoR = tmux(['display-message', '-p', '-t', target,
    '#{window_width}\t#{window_height}'], { allowFail: true }).trim();
  const [wwR, whR] = winInfoR.split('\t').map(n => parseInt(n, 10));
  const planR = computeResponsiveLayout(wwR, whR, cfg.sidebarWidth || SIDEBAR_WIDTH, {
    hasRight: true,
    wantSub: isWideAspect(wwR, whR),
  });
  if (planR.subWidth > 0) {
    tmux(['split-window', '-t', main.pid, '-h', '-l', String(planR.subWidth), '-c', cwd, shell],
      { allowFail: true });
    tmux(['select-pane', '-t', target, '-T', paneTitleFor(projName, 'sub')],
      { allowFail: true });
    tmux(['select-pane', '-t', main.pid], { allowFail: true });
  }
  tmux(['split-window', '-t', main.pid, '-h', '-l', String(planR.rightWidth), '-c', cwd,
    `bash -lc ${shEsc(`exec ${NMUX_BIN} task-overlay --cwd ${shQuote(cwd)}`)}`],
    { allowFail: true });
  tmux(['select-pane', '-t', target, '-T', paneTitleFor(projName, 'status')],
    { allowFail: true });
  tmux(['split-window', '-t', target, '-v', '-l', '50%', '-c', cwd, shell],
    { allowFail: true });
  tmux(['select-pane', '-t', target, '-T', paneTitleFor(projName, 'bash')],
    { allowFail: true });
  tmux(['select-pane', '-t', main.pid], { allowFail: true });
  console.log('relayout done');
}

function applySession({ replace = false } = {}) {
  let cfg = loadConfig() || initConfig();
  let state = loadState();
  if (sessionExists(cfg.session)) {
    if (!replace) { installBindings(cfg.session); return cfg; }
    captureAndSaveOpen(cfg.session);
    state = loadState();
    tmux(['kill-session', '-t', cfg.session]);
  }
  const known = new Map(cfg.projects.map(p => [p.name, p]));
  let toOpen = (state.open || []).filter(n => known.has(n)).map(n => known.get(n));
  if (!toOpen.length) toOpen = cfg.projects.slice(0, 1);
  if (!toOpen.length) throw new Error('no projects to open. Run `nmux-linux init` or `nmux-linux add <name> <path>`.');
  toOpen.forEach((p, i) => buildWindow(cfg, p, i === 0));
  // base-index can only take effect for FUTURE new-window calls, so the
  // initial new-session created window 0 even though our session-level
  // base-index is 1. Renumber once everything's built.
  tmux(['move-window', '-r', '-s', cfg.session], { allowFail: true });
  const firstIdx = (tmux(['list-windows', '-t', cfg.session, '-F', '#{window_index}'], { allowFail: true })
    .split('\n')[0] || '1').trim() || '1';
  tmux(['select-window', '-t', `${cfg.session}:${firstIdx}`], { allowFail: true });
  saveState({ open: toOpen.map(p => p.name) });
  return cfg;
}

function captureAndSaveOpen(session) {
  if (!sessionExists(session)) return;
  const out = tmux(['list-windows', '-t', session, '-F',
    '#{@nmuxlinux_project}\t#{window_name}'], { allowFail: true });
  const open = [];
  for (const line of out.split('\n')) {
    if (!line) continue;
    const [proj, name] = line.split('\t');
    const key = proj || (name || '').replace(/^[✓✕?…! ]+\s*/, '');
    if (key) open.push(key);
  }
  const cur = loadState();
  saveState({ ...cur, open });
}

function attach(session) {
  if (process.env.TMUX) {
    spawnSync('tmux', ['switch-client', '-t', session], { stdio: 'inherit' });
  } else {
    spawnSync('tmux', ['attach-session', '-t', session], { stdio: 'inherit' });
  }
}

// ---------- live ops ----------
function userMsg(text, dur = 2500) {
  spawnSync('tmux', ['display-message', '-d', String(dur), '-t', SESSION, String(text)], { stdio: 'ignore' });
}

function findInRegistryOrPath(arg) {
  let cfg = loadConfig() || initConfig();
  let proj = cfg.projects.find(p => p.name === arg);
  if (proj) return { cfg, proj, registered: true };

  let cwd = null;
  if (path.isAbsolute(arg) && fs.existsSync(arg)) cwd = arg;
  if (!cwd) for (const root of SCAN_ROOTS) {
    const c = path.join(root, arg);
    if (fs.existsSync(c)) { cwd = c; break; }
  }
  if (!cwd) {
    const r = path.resolve(arg);
    if (fs.existsSync(r)) cwd = r;
  }

  // Nothing exists yet — auto-create the directory so "new project" really
  // creates one. Bare names land under ~/projects/<name>; slashed args are
  // taken as relative or absolute paths.
  if (!cwd) {
    let newCwd;
    if (path.isAbsolute(arg)) newCwd = arg;
    else if (arg.includes('/')) newCwd = path.resolve(arg);
    else newCwd = path.join(SCAN_ROOTS[0], arg);
    try { fs.mkdirSync(newCwd, { recursive: true }); }
    catch (e) { throw new Error(`mkdir ${newCwd}: ${e.message}`); }
    cwd = newCwd;
  }

  const name = (path.basename(cwd) || arg).replace(/[:.\s]/g, '-').slice(0, 40);
  proj = cfg.projects.find(p => p.name === name);
  if (!proj) {
    proj = defaultProject(name, cwd);
    cfg.projects.unshift(proj);
    saveConfig(cfg);
  }
  return { cfg, proj, registered: false };
}

function nudgeSidebars() {
  // SIGUSR1 every nmux-linux-sidebar process so they repaint immediately.
  try {
    for (const child of fs.readdirSync('/proc')) {
      if (!/^\d+$/.test(child)) continue;
      try {
        const cmd = fs.readFileSync(`/proc/${child}/cmdline`, 'utf8');
        if (cmd.includes('nmux-linux-sidebar')) process.kill(parseInt(child, 10), 'SIGUSR1');
      } catch {}
    }
  } catch {}
}

function openProject(arg) {
  if (!arg) throw new Error('usage: nmux-linux open <name|path>');
  let cfg, proj;
  try {
    ({ cfg, proj } = findInRegistryOrPath(arg));
  } catch (e) {
    userMsg(`nmux-linux: ${e.message}`, 4000);
    throw e;
  }
  if (!sessionExists(cfg.session)) {
    saveState({ ...loadState(), open: [proj.name] });
    applySession();
    attach(cfg.session);
    return;
  }
  const out = tmux(['list-windows', '-t', cfg.session, '-F', '#{@nmuxlinux_project}\t#{window_index}'], { allowFail: true });
  for (const line of out.split('\n')) {
    if (!line) continue;
    const [n, idx] = line.split('\t');
    if (n === proj.name) {
      tmux(['select-window', '-t', `${cfg.session}:${idx}`]);
      nudgeSidebars();
      userMsg(`nmux-linux: switched to ${proj.name}`);
      return;
    }
  }
  buildWindow(cfg, proj, false);
  captureAndSaveOpen(cfg.session);
  nudgeSidebars();
  userMsg(`nmux-linux: opened ${proj.name} (${proj.cwd})`, 3500);
}

function closeWindow(idx) {
  if (!idx) return;
  if (!sessionExists(SESSION)) return;
  tmux(['kill-window', '-t', `${SESSION}:${idx}`], { allowFail: true });
  setTimeout(() => captureAndSaveOpen(SESSION), 50);
}
function closeCurrent() {
  if (!process.env.TMUX) { console.error('not inside tmux'); return; }
  const info = tmux(['display-message', '-p', '#{session_name}\t#{window_index}'], { allowFail: true });
  const [s, idx] = info.split('\t');
  if (s !== SESSION) return;
  closeWindow(idx);
}

function killOmxHudPanes() {
  // Identify panes whose process tree runs `omx hud --watch` and kill them.
  if (!sessionExists(SESSION)) return 0;
  const proc = readProcIndex();
  const out = tmux(['list-panes', '-s', '-t', SESSION, '-F', '#{pane_id}\t#{pane_pid}\t#{pane_current_command}'], { allowFail: true });
  let killed = 0;
  for (const line of out.split('\n')) {
    if (!line) continue;
    const [pid, ppid, paneCmd] = line.split('\t');
    if (paneIsOmxHud(ppid, proc, paneCmd)) {
      tmux(['kill-pane', '-t', pid], { allowFail: true });
      killed++;
    }
  }
  return killed;
}

function normalizeCmdline(cmd) {
  return String(cmd || '').replace(/\0/g, ' ').trim();
}

function commandLooksLikeOmxHud(cmd) {
  const c = normalizeCmdline(cmd);
  if (!c) return false;
  return /(?:^|\s)hud\s+.*?--watch(?:[\s=]|$)/.test(c)
    && /(?:^|[\/\s])(?:omx|omx\.js)(?:[\s]|$)/.test(c);
}

function readProcIndex() {
  const commands = new Map();
  const children = new Map();
  try {
    for (const ent of fs.readdirSync('/proc')) {
      if (!/^\d+$/.test(ent)) continue;
      const pid = String(ent);
      let ppid = null;
      try {
        const stat = fs.readFileSync(`/proc/${pid}/stat`, 'utf8');
        ppid = stat.split(') ').pop().split(' ')[1];
      } catch {}
      if (ppid) {
        if (!children.has(ppid)) children.set(ppid, []);
        children.get(ppid).push(pid);
      }
      try {
        commands.set(pid, fs.readFileSync(`/proc/${pid}/cmdline`, 'utf8'));
      } catch {}
    }
  } catch {}
  return { commands, children };
}

function paneIsOmxHud(rootPid, proc = readProcIndex(), paneCurrentCommand = '') {
  if (!rootPid) return false;
  if (paneCurrentCommand && paneCurrentCommand !== 'omx' && paneCurrentCommand !== 'node') {
    // Fast negative for common shells/editors; still inspect descendants when
    // tmux reports a generic launcher that could own the real omx process.
  }
  const stack = [String(rootPid)];
  const seen = new Set();
  while (stack.length) {
    const p = stack.pop();
    if (!p || seen.has(p)) continue;
    seen.add(p);
    if (commandLooksLikeOmxHud(proc.commands.get(p))) return true;
    for (const child of proc.children.get(p) || []) stack.push(child);
  }
  return false;
}

const HUD_DISABLE_MARKER = path.join(CONFIG_DIR, 'disable-hud-omx');

function resolveOmxHudPaths() {
  const candidates = [];
  try {
    const omxBin = spawnSync('which', ['omx'], { encoding: 'utf8' }).stdout.trim();
    if (omxBin) {
      const real = fs.realpathSync(omxBin);
      const pkgRoot = path.resolve(path.dirname(real), '..', '..', 'lib', 'node_modules', 'oh-my-codex');
      candidates.push(pkgRoot);
      candidates.push(path.resolve(path.dirname(real), '..', 'lib', 'node_modules', 'oh-my-codex'));
    }
  } catch {}
  try {
    const npmRoot = spawnSync('npm', ['root', '-g'], { encoding: 'utf8' }).stdout.trim();
    if (npmRoot) candidates.push(path.join(npmRoot, 'oh-my-codex'));
  } catch {}
  for (const home of [os.homedir(), '/usr/local', '/usr']) {
    candidates.push(path.join(home, '.local', 'lib', 'node_modules', 'oh-my-codex'));
    candidates.push(path.join(home, 'lib', 'node_modules', 'oh-my-codex'));
  }
  for (const root of candidates) {
    const reconcile = path.join(root, 'dist', 'hud', 'reconcile.js');
    const hud = path.join(root, 'dist', 'hud', 'tmux.js');
    if (fs.existsSync(reconcile) && fs.existsSync(hud)) {
      return { reconcile, hud, root };
    }
  }
  return null;
}

function patchOmxReconcile() {
  const paths = resolveOmxHudPaths();
  if (!paths) {
    console.error('[nmux-linux] omx (oh-my-codex) not found — skipping omx HUD opt-out patch');
    console.error('[nmux-linux] (the marker file still suppresses HUD if omx is installed later)');
    return false;
  }
  const ok1 = patchReconcileFile(paths.reconcile);
  const ok2 = patchHudTmuxFile(paths.hud);
  return ok1 && ok2;
}

function patchReconcileFile(reconcilePath) {
  if (!fs.existsSync(reconcilePath)) {
    console.error(`[nmux-linux] reconcile.js not found at ${reconcilePath}`);
    return false;
  }
  let src = fs.readFileSync(reconcilePath, 'utf8');
  if (src.includes('__nmuxlinux_marker') && src.includes('__nmuxlinux_existsSync')) return true;

  if (!src.includes('__nmuxlinux_existsSync')) {
    const importAnchor = `import { resolveOmxCliEntryPath } from '../utils/paths.js';`;
    if (!src.includes(importAnchor)) { console.error('[nmux-linux] reconcile.js imports unexpected'); return false; }
    src = src.replace(importAnchor, importAnchor +
      `\nimport { existsSync as __nmuxlinux_existsSync } from 'fs';` +
      `\nimport { homedir as __nmuxlinux_homedir } from 'os';` +
      `\nimport { join as __nmuxlinux_join } from 'path';`);
  }
  const insertAfter = `if (!env.TMUX) {
        return {
            status: 'skipped_not_tmux',
            paneId: null,
            desiredHeight: null,
            duplicateCount: 0,
        };
    }`;
  if (!src.includes(insertAfter)) { console.error('[nmux-linux] reconcile.js shape unexpected'); return false; }
  const inject = `
    try {
        const __nmuxlinux_marker = __nmuxlinux_join(__nmuxlinux_homedir(), '.config', 'nmux-linux', 'disable-hud-omx');
        if (env.NMUX_LINUX_DISABLE_HUD === '1' || env.OMX_HUD_DISABLE === '1' || __nmuxlinux_existsSync(__nmuxlinux_marker)) {
            return {
                status: 'skipped_disabled',
                paneId: null,
                desiredHeight: null,
                duplicateCount: 0,
            };
        }
    } catch (_) { /* ignore */ }`;
  src = src.replace(insertAfter, insertAfter + inject);
  fs.writeFileSync(reconcilePath, src);
  console.log(`[nmux-linux] patched ${reconcilePath}`);
  return true;
}

function patchHudTmuxFile(hudPath) {
  if (!fs.existsSync(hudPath)) {
    console.error(`[nmux-linux] hud/tmux.js not found at ${hudPath}`);
    return false;
  }
  let src = fs.readFileSync(hudPath, 'utf8');
  if (src.includes('__nmuxlinux_hudSuppressed')) return true;

  const importAnchor = `import { resolveTmuxBinaryForPlatform } from '../utils/platform-command.js';`;
  if (!src.includes(importAnchor)) { console.error('[nmux-linux] hud/tmux.js imports unexpected'); return false; }
  src = src.replace(importAnchor, importAnchor +
    `\nimport { existsSync as __nmuxlinux_existsSync } from 'fs';` +
    `\nimport { homedir as __nmuxlinux_homedir } from 'os';` +
    `\nimport { join as __nmuxlinux_join } from 'path';` +
    `\nfunction __nmuxlinux_hudSuppressed() {` +
    `\n    try {` +
    `\n        if (process.env.NMUX_LINUX_DISABLE_HUD === '1' || process.env.OMX_HUD_DISABLE === '1') return true;` +
    `\n        return __nmuxlinux_existsSync(__nmuxlinux_join(__nmuxlinux_homedir(), '.config', 'nmux-linux', 'disable-hud-omx'));` +
    `\n    } catch (_) { return false; }` +
    `\n}`);

  const fnAnchor = `export function createHudWatchPane(cwd, hudCmd, options = {}, execTmuxSync = defaultExecTmuxSync) {`;
  if (!src.includes(fnAnchor)) { console.error('[nmux-linux] createHudWatchPane signature changed'); return false; }
  src = src.replace(fnAnchor, fnAnchor +
    `\n    if (__nmuxlinux_hudSuppressed()) return null;`);

  fs.writeFileSync(hudPath, src);
  console.log(`[nmux-linux] patched ${hudPath}`);
  return true;
}

function disableOmxHud() {
  const ok = patchOmxReconcile();
  // Marker file works for *all* shell processes (including ones started before
  // we set the tmux session env), since reconcile.js just stat()s it on every
  // prompt. Even if the source patch failed, an installed marker still has
  // value when omx is later patched/installed, but we surface failure clearly.
  ensureConfigDir();
  writeAtomic(HUD_DISABLE_MARKER, 'nmux-linux: HUD reconcile suppressed\n');
  if (!ok) {
    console.error('[nmux-linux] WARN: omx source patch failed — marker is in place but');
    console.error('  omx will only honor it on a build that has been patched. Run');
    console.error('  `nmux-linux disable-omx-hud` again after omx upgrade/reinstall.');
    process.exitCode = 1;
  }
  console.log(`[nmux-linux] marker written: ${HUD_DISABLE_MARKER}`);

  if (sessionExists(SESSION)) {
    tmux(['set-environment', '-t', SESSION, 'NMUX_LINUX_DISABLE_HUD', '1'], { allowFail: true });
    const killed = killOmxHudPanes();
    console.log(`[nmux-linux] NMUX_LINUX_DISABLE_HUD=1 set on session; ${killed} stale HUD pane(s) killed.`);
  }
}

function enableOmxHud() {
  // Reverse switch: remove marker + unset env. Patched reconcile stays;
  // it's harmless when no marker/env is present.
  try { fs.unlinkSync(HUD_DISABLE_MARKER); console.log(`[nmux-linux] marker removed`); } catch {}
  if (sessionExists(SESSION)) {
    tmux(['set-environment', '-t', SESSION, '-u', 'NMUX_LINUX_DISABLE_HUD'], { allowFail: true });
  }
}

function hudSuppressionActive() {
  if (process.env.NMUX_LINUX_DISABLE_HUD === '1' || process.env.OMX_HUD_DISABLE === '1') return true;
  if (fs.existsSync(HUD_DISABLE_MARKER)) return true;
  if (sessionExists(SESSION)) {
    const env = tmux(['show-environment', '-t', SESSION, 'NMUX_LINUX_DISABLE_HUD'], { allowFail: true });
    if (/NMUX_LINUX_DISABLE_HUD=1/.test(env)) return true;
  }
  return false;
}

function resizePaneWidth(pid, width, currentWidth) {
  const w = Math.max(1, Math.floor(Number(width) || 1));
  if (!pid) return;
  if (Number.isFinite(currentWidth) && Math.abs(currentWidth - w) <= 1) return;
  tmux(['resize-pane', '-t', pid, '-x', String(w)], { allowFail: true });
}

function convergeResponsiveWindowLayout(cfg, info) {
  if (!info || !info.panes || !info.panes.length) return;
  const sidebar = info.panes.find(p => p.isSidebar);
  const main = info.panes.find(p => paneRoleOf(p.title) === 'main')
    || info.panes.find(p => !p.isSidebar && !isReservedPaneTitle(p.title));
  const status = info.panes.find(p => paneRoleOf(p.title) === 'status')
    || info.panes.find(p => paneRoleOf(p.title) === 'webview');
  const bash = info.panes.find(p => paneRoleOf(p.title) === 'bash');
  const sub = info.panes.find(p => paneRoleOf(p.title) === 'sub');
  const plan = computeResponsiveLayout(info.winW, info.winH, cfg.sidebarWidth || SIDEBAR_WIDTH, {
    hasRight: !!(status || bash),
    hasSub: !!sub,
    wantSub: isWideAspect(info.winW, info.winH),
  });

  // Two passes converge better because tmux redistributes cells from
  // neighbouring panes on every absolute resize.
  for (let pass = 0; pass < 2; pass++) {
    if (sidebar) resizePaneWidth(sidebar.pid, plan.sidebarWidth, sidebar.width);
    if (main) resizePaneWidth(main.pid, plan.mainWidth, main.width);
    if (sub) resizePaneWidth(sub.pid, plan.subWidth || 1, sub.width);
    if (status) resizePaneWidth(status.pid, plan.rightWidth || 1, status.width);
    if (bash) resizePaneWidth(bash.pid, plan.rightWidth || 1, bash.width);
  }
}

function fixLayout() {
  // tmux scales panes proportionally on resize; converge every nmux-linux
  // window back to a monitor-size-aware layout. Small clients get a narrower
  // sidebar and collapsed auxiliary pane; wide clients keep the larger
  // proportions. Automatic resize never kills panes.
  if (process.env.NMUX_LINUX_HOOK_SESSION && process.env.NMUX_LINUX_HOOK_SESSION !== SESSION) return;
  if (!sessionExists(SESSION)) return;
  const cfg = loadConfig() || initConfig();
  const out = tmux(['list-panes', '-s', '-t', SESSION, '-F',
    '#{window_id}\t#{window_index}\t#{pane_id}\t#{pane_title}\t#{pane_pid}\t#{pane_width}\t#{window_width}\t#{window_height}\t#{@nmuxlinux_project}\t#{pane_current_path}\t#{pane_current_command}'],
    { allowFail: true });
  const byWin = new Map();
  for (const line of out.split('\n')) {
    if (!line) continue;
    const [wid, widx, pid, title, ppid, widthStr, winWStr, winHStr, proj, paneCwd, paneCmd] = line.split('\t');
    const isSidebar = title === 'nmux-linux-sidebar' || isSidebarPid(ppid);
    const width = parseInt(widthStr, 10) || 0;
    if (!byWin.has(wid)) byWin.set(wid, {
      idx: widx,
      proj,
      paneCwd,
      winW: parseInt(winWStr, 10),
      winH: parseInt(winHStr, 10),
      panes: [],
    });
    byWin.get(wid).panes.push({ pid, title, ppid, isSidebar, width, paneCwd, paneCmd });
  }
  for (const [, info] of byWin) {
    rebuildMissingMain(cfg, info);
    ensureTaskOverlay(cfg, info);
    convergeResponsiveWindowLayout(cfg, info);
  }
  if (hudSuppressionActive()) killOmxHudPanes();
}

function paneRunsTaskOverlay(rootPid) {
  if (!rootPid) return false;
  const proc = readProcIndex();
  const stack = [String(rootPid)];
  const seen = new Set();
  while (stack.length) {
    const p = stack.pop();
    if (!p || seen.has(p)) continue;
    seen.add(p);
    const cmd = normalizeCmdline(proc.commands.get(p));
    if (cmd.includes('nmux-linux task-overlay') || cmd.includes('task-overlay --cwd')) return true;
    for (const child of proc.children.get(p) || []) stack.push(child);
  }
  return false;
}

function ensureTaskOverlay(cfg, info) {
  if (!info || !info.panes.length || !info.proj) return;
  // A webview pane intentionally owns the status slot until the user runs
  // refresh-overlays/resize-cols, so don't overwrite it from fix-layout.
  if (info.panes.some(p => paneRoleOf(p.title) === 'webview')) return;
  const statuses = info.panes.filter(p => paneRoleOf(p.title) === 'status');
  const status = statuses[0];
  for (const extra of statuses.slice(1)) {
    tmux(['kill-pane', '-t', extra.pid], { allowFail: true });
  }
  const project = (cfg.projects || []).find(p => p.name === info.proj);
  const cwd = (project && project.cwd) || info.paneCwd || HOME;
  if (status) {
    if (!paneRunsTaskOverlay(status.ppid)) {
      tmux(['respawn-pane', '-k', '-t', status.pid, '-c', cwd,
        `bash -lc ${shEsc(`exec ${NMUX_BIN} task-overlay --cwd ${shQuote(cwd)}`)}`],
        { allowFail: true });
      tmux(['select-pane', '-t', status.pid, '-T', paneTitleFor(info.proj, 'status')],
        { allowFail: true });
    }
    return;
  }

  const main = info.panes.find(p => paneRoleOf(p.title) === 'main')
    || info.panes.find(p => !p.isSidebar && !isReservedPaneTitle(p.title));
  if (!main) return;
  const plan = computeResponsiveLayout(info.winW, info.winH, cfg.sidebarWidth || SIDEBAR_WIDTH, {
    hasRight: true,
    hasSub: info.panes.some(p => paneRoleOf(p.title) === 'sub'),
  });
  const newPaneId = tmux(['split-window', '-t', main.pid, '-h', '-l', String(plan.rightWidth || 1), '-c', cwd,
    '-P', '-F', '#{pane_id}',
    `bash -lc ${shEsc(`exec ${NMUX_BIN} task-overlay --cwd ${shQuote(cwd)}`)}`],
    { allowFail: true }).trim();
  if (newPaneId) {
    tmux(['select-pane', '-t', newPaneId, '-T', paneTitleFor(info.proj, 'status')],
      { allowFail: true });
    tmux(['select-pane', '-t', main.pid], { allowFail: true });
  }
}

// If a window has a sidebar but no "main" project pane, the layout looks
// broken — the user clicks the project in the sidebar and lands on a
// half-empty window with no shell. Re-add the main shell adjacent to the
// sidebar without touching the right column (which may hold the user's
// running work). Idempotent: bails out when a main is already present.
function rebuildMissingMain(cfg, info) {
  if (!info || !info.panes.length) return;
  const sidebar = info.panes.find(p => p.isSidebar);
  if (!sidebar) return;
  const main = info.panes.find(p => !p.isSidebar && !isReservedPaneTitle(p.title));
  if (main) return;
  const projName = info.proj;
  if (!projName) return;
  const proj = (cfg.projects || []).find(p => p.name === projName);
  const cwd = (proj && proj.cwd) || process.env.HOME || '/';
  const shell = process.env.SHELL || '/bin/bash';
  // Split the sidebar so the new main appears to its right. `-P -F` makes
  // tmux print the new pane id so we can address it directly afterwards
  // (the previously-active "{last}" pane is the sidebar — wrong target).
  const newPaneId = tmux(['split-window', '-t', sidebar.pid, '-h', '-c', cwd,
    '-P', '-F', '#{pane_id}', shell], { allowFail: true }).trim();
  // Tag the new pane with the project name so subsequent findMainPane /
  // focusMainPane calls can locate it.
  if (newPaneId) tmux(['select-pane', '-t', newPaneId, '-T', paneTitleFor(projName, 'main')], { allowFail: true });
  // Re-pin the sidebar — the split shrank it by half.
  const plan = computeResponsiveLayout(info.winW, info.winH, cfg.sidebarWidth || SIDEBAR_WIDTH, {
    hasRight: info.panes.some(p => paneRoleOf(p.title) === 'status' || paneRoleOf(p.title) === 'bash'),
    hasSub: info.panes.some(p => paneRoleOf(p.title) === 'sub'),
  });
  const sw = plan.sidebarWidth;
  tmux(['resize-pane', '-t', sidebar.pid, '-x', String(sw)], { allowFail: true });
  // The new main is half of the original sidebar (≈13 cells). Grow it to
  // roughly (window_width - sidebar)/2 so the layout matches a freshly
  // built window. Read window_width post-resize so border cells are
  // accounted for.
  if (newPaneId) {
    const winInfo = tmux(['display-message', '-p', '-t', `${cfg.session}:${info.idx}`,
      '#{window_width}'], { allowFail: true }).trim();
    const winW = parseInt(winInfo, 10);
    if (Number.isFinite(winW) && winW > sw + 4) {
      const mainPlan = computeResponsiveLayout(winW, info.winH, cfg.sidebarWidth || SIDEBAR_WIDTH, {
        hasRight: info.panes.some(p => paneRoleOf(p.title) === 'status' || paneRoleOf(p.title) === 'bash'),
        hasSub: info.panes.some(p => paneRoleOf(p.title) === 'sub'),
      });
      const mainW = Math.max(20, mainPlan.mainWidth);
      tmux(['resize-pane', '-t', newPaneId, '-x', String(mainW)], { allowFail: true });
    }
  }
}

// Respawn each window's right-top pane so it runs the task overlay.
// right-bot stays as the user-owned bash shell under the new 3-column
// layout — no overlay there so ad-hoc commands aren't fighting a
// redrawing TUI. For git status in that pane, run
// `nmux-linux git-overlay --cwd <path>` manually.
function refreshOverlays() {
  if (!sessionExists(SESSION)) return;
  const cfg = loadConfig() || initConfig();
  const out = tmux(['list-panes', '-s', '-t', SESSION, '-F',
    '#{window_index}\t#{pane_id}\t#{pane_title}\t#{@nmuxlinux_project}\t#{pane_current_path}'],
    { allowFail: true });
  let topCount = 0;
  for (const line of out.split('\n')) {
    if (!line) continue;
    const [, pid, title, proj, paneCwd] = line.split('\t');
    if (paneRoleOf(title) !== 'status') continue;
    const project = (cfg.projects || []).find(p => p.name === proj);
    const cwd = (project && project.cwd) || paneCwd || HOME;
    tmux(['respawn-pane', '-k', '-t', pid, '-c', cwd,
      `bash -lc ${shEsc(`exec ${NMUX_BIN} task-overlay --cwd ${shQuote(cwd)}`)}`], { allowFail: true });
    tmux(['select-pane', '-t', pid, '-T', paneTitleFor(proj || '', 'status')], { allowFail: true });
    topCount++;
  }
  console.log(`refreshed ${topCount} right-top pane(s); right-bot left as user shell`);
}

// Retrofit existing windows to the 3-column layout: add a `code-mid`
// pane to the right of the main coding pane. Preserves main's process
// (no respawn) so any running agent / editor stays alive. Right
// column is left as-is — that work survives too.
// Non-destructive: walk every nmux-linux window and resize the
// existing 5-pane layout to match the configured proportions. No
// kill-pane, no respawn — user's running work is preserved.
// Apply the canonical layout across every existing nmux-linux window:
// retitle to project-prefixed names, reorder columns so the status/bash
// column sits between main and sub (or drop sub on 16:9), and resize
// to the spec'd proportions. Destructive only for right-top/right-bot
// (task-overlay daemon is regenerated; right-bot bash loses history).
// Main and sub processes are preserved.
function resizeCols() {
  if (!sessionExists(SESSION)) return;
  const cfg = loadConfig() || initConfig();
  const shell = process.env.SHELL || '/bin/bash';
  const out = tmux(['list-panes', '-s', '-t', SESSION, '-F',
    '#{window_index}\t#{pane_id}\t#{pane_title}\t#{window_width}\t#{window_height}\t#{@nmuxlinux_project}\t#{pane_current_path}'],
    { allowFail: true });
  const byWin = new Map();
  for (const line of out.split('\n')) {
    if (!line) continue;
    const [widx, pid, title, ww, wh, proj, paneCwd] = line.split('\t');
    if (!byWin.has(widx)) byWin.set(widx, {
      winW: parseInt(ww, 10), winH: parseInt(wh, 10), proj, paneCwd, panes: [],
    });
    byWin.get(widx).panes.push({ pid, title });
  }
  let resized = 0, skipped = 0;
  for (const [widx, info] of byWin) {
    const sidebar = info.panes.find(p => p.title === 'nmux-linux-sidebar');
    if (!sidebar) { skipped++; continue; }
    const nonSidebar = info.panes.filter(p => p.pid !== sidebar.pid);
    const statuses = nonSidebar.filter(p => paneRoleOf(p.title) === 'status');
    const bashes = nonSidebar.filter(p => paneRoleOf(p.title) === 'bash');
    const status = statuses[0];
    const bash = bashes[0];
    let sub = nonSidebar.find(p => paneRoleOf(p.title) === 'sub');
    // Main is whatever's left after extracting reserved roles.
    const main = nonSidebar.find(p => {
      const r = paneRoleOf(p.title);
      return r === 'main' || r === null; // null = legacy plain title
    });
    if (!main) { skipped++; continue; }
    const projName = info.proj || '';
    if (!projName) { skipped++; continue; }
    const project = (cfg.projects || []).find(p => p.name === projName);
    const cwd = (project && project.cwd) || info.paneCwd || HOME;
    const plan = computeResponsiveLayout(info.winW, info.winH, cfg.sidebarWidth || SIDEBAR_WIDTH, {
      hasRight: true,
      hasSub: !!sub,
      wantSub: isWideAspect(info.winW, info.winH),
    });
    const sw = plan.sidebarWidth;
    const wide = plan.canFullSub;
    const rightW = plan.rightWidth || 1;
    const subW = plan.subWidth || 0;
    const mainW = Math.max(20, plan.mainWidth);

    // Step 1: drop the right column (always — we rebuild it on the
    // correct side of sub). Drop sub too if we're on a 16:9 display.
    for (const p of statuses) tmux(['kill-pane', '-t', p.pid], { allowFail: true });
    for (const p of bashes) tmux(['kill-pane', '-t', p.pid], { allowFail: true });
    if (!wide && sub) {
      tmux(['kill-pane', '-t', sub.pid], { allowFail: true });
      sub = null;
    }

    const target = `${SESSION}:${widx}`;

    // Step 2: split right of main → status column. Inserts BETWEEN
    // main and sub (on wide) or at the far right (on 16:9). Width
    // approximated; we re-resize at the end.
    tmux(['split-window', '-t', main.pid, '-h', '-l', String(rightW), '-c', cwd,
      `bash -lc ${shEsc(`exec ${NMUX_BIN} task-overlay --cwd ${shQuote(cwd)}`)}`],
      { allowFail: true });
    tmux(['select-pane', '-t', target, '-T', paneTitleFor(projName, 'status')],
      { allowFail: true });
    tmux(['split-window', '-t', target, '-v', '-l', '50%', '-c', cwd, shell],
      { allowFail: true });
    tmux(['select-pane', '-t', target, '-T', paneTitleFor(projName, 'bash')],
      { allowFail: true });

    // Step 3: retitle main + sub.
    tmux(['select-pane', '-t', main.pid, '-T', paneTitleFor(projName, 'main')],
      { allowFail: true });
    if (sub) {
      tmux(['select-pane', '-t', sub.pid, '-T', paneTitleFor(projName, 'sub')],
        { allowFail: true });
    }

    // Step 4: converge widths (two passes — first one perturbs
    // neighbours, second corrects).
    const newStatus = tmux(['list-panes', '-t', target, '-F',
      '#{pane_id}\t#{pane_title}'], { allowFail: true }).split('\n')
      .filter(Boolean).map(l => l.split('\t'))
      .find(([_, t]) => paneRoleOf(t) === 'status');
    for (let pass = 0; pass < 2; pass++) {
      tmux(['resize-pane', '-t', sidebar.pid, '-x', String(sw)], { allowFail: true });
      tmux(['resize-pane', '-t', main.pid, '-x', String(mainW)], { allowFail: true });
      if (sub) tmux(['resize-pane', '-t', sub.pid, '-x', String(subW)], { allowFail: true });
      if (newStatus) tmux(['resize-pane', '-t', newStatus[0], '-x', String(rightW)], { allowFail: true });
    }
    tmux(['select-pane', '-t', main.pid], { allowFail: true });
    resized++;
  }
  console.log(`resized ${resized} window(s); ${skipped} skipped`);
}

function relayout3col() {
  if (!sessionExists(SESSION)) return;
  const cfg = loadConfig() || initConfig();
  const out = tmux(['list-panes', '-s', '-t', SESSION, '-F',
    '#{window_index}\t#{pane_id}\t#{pane_title}\t#{@nmuxlinux_project}\t#{pane_current_path}'],
    { allowFail: true });
  const byWin = new Map();
  for (const line of out.split('\n')) {
    if (!line) continue;
    const [widx, pid, title, proj, paneCwd] = line.split('\t');
    if (!byWin.has(widx)) byWin.set(widx, { proj, paneCwd, panes: [] });
    byWin.get(widx).panes.push({ pid, title });
  }
  const shell = process.env.SHELL || '/bin/bash';
  let added = 0, skipped = 0;
  for (const [widx, info] of byWin) {
    if (info.panes.some(p => paneRoleOf(p.title) === 'sub')) { skipped++; continue; }
    const main = info.panes.find(p => !isReservedPaneTitle(p.title));
    if (!main) { skipped++; continue; }
    const project = (cfg.projects || []).find(p => p.name === info.proj);
    const cwd = (project && project.cwd) || info.paneCwd || HOME;
    tmux(['split-window', '-t', main.pid, '-h', '-l', '50%', '-c', cwd, shell], { allowFail: true });
    tmux(['select-pane', '-t', `${SESSION}:${widx}`, '-T', paneTitleFor(info.proj || '', 'sub')], { allowFail: true });
    tmux(['select-pane', '-t', main.pid], { allowFail: true });
    added++;
  }
  console.log(`added code-mid to ${added} window(s); ${skipped} already had it or no main`);
}

function refreshSidebars() {
  if (!sessionExists(SESSION)) return;
  const out = tmux(['list-panes', '-s', '-t', SESSION, '-F', '#{pane_id}\t#{pane_pid}\t#{pane_title}'], { allowFail: true });
  let hits = 0;
  for (const line of out.split('\n')) {
    if (!line) continue;
    const [pid, ppid, title] = line.split('\t');
    const match = title === 'nmux-linux-sidebar' || isSidebarPid(ppid);
    if (!match) continue;
    hits++;
    tmux(['respawn-pane', '-k', '-t', pid,
          `bash -lc ${shEsc(`NMUX_LINUX_SESSION=${SESSION} exec ${SIDEBAR_HELPER}`)}`], { allowFail: true });
    tmux(['select-pane', '-t', pid, '-T', 'nmux-linux-sidebar'], { allowFail: true });
  }
  console.log(`refreshed ${hits} sidebar pane(s)`);
}
function isSidebarPid(pid) {
  if (!pid) return false;
  try {
    const cmd = fs.readFileSync(`/proc/${pid}/cmdline`, 'utf8');
    if (cmd.includes('nmux-linux-sidebar')) return true;
    for (const child of fs.readdirSync('/proc')) {
      if (!/^\d+$/.test(child)) continue;
      try {
        const stat = fs.readFileSync(`/proc/${child}/stat`, 'utf8');
        const ppid = stat.split(') ').pop().split(' ')[1];
        if (String(ppid) !== String(pid)) continue;
        const ccmd = fs.readFileSync(`/proc/${child}/cmdline`, 'utf8');
        if (ccmd.includes('nmux-linux-sidebar')) return true;
      } catch {}
    }
  } catch {}
  return false;
}

// ---------- prompt + click + kill ----------
// Quote-safe prompt: tmux's command-prompt %% substitution literally
// inserts user input into the template, then the result is *re-parsed* as
// tmux commands. A quote / semicolon / double-quote in the input fragments
// the command boundaries ("too many arguments" or, worse, command injection).
// We instead use display-popup -E to spawn an interactive shell where
// `read -r` captures the line as a literal bash string, and exec our
// binary with the value already-properly-quoted by bash.
function promptCommand() {
  // POSIX-sh compatible read (display-popup -E uses /bin/sh, and dash on
  // Debian/Ubuntu does NOT support `read -p`). Use printf + read -r.
  const cmd =
    `printf 'project (name|path): '; ` +
    `IFS= read -r __nmux_input || exit 0; ` +
    `[ -n "$__nmux_input" ] || exit 0; ` +
    `exec ${shQuote(NMUX_BIN)} open "$__nmux_input"`;
  // tmux ≥ 3.2 has display-popup. Try it first.
  const popup = spawnSync('tmux', ['display-popup', '-E', cmd], { stdio: 'ignore' });
  if (popup.status === 0) return;
  // Fallback for old tmux without display-popup. Single-command template
  // (no chained `;`) so a quote in user input fails parsing inside tmux
  // rather than escaping into shell.
  spawnSync('tmux', ['command-prompt', '-1', '-p', 'project (name|path):',
                     `run-shell ${shQuote(`${NMUX_BIN} open '%%'`)}`], { stdio: 'ignore' });
}

function confirmKill() {
  // tmux confirm-before runs the command on 'y' confirmation.
  spawnSync('tmux', ['confirm-before', '-p', 'kill nmux-linux session? (y/n) ',
    `run-shell ${shQuote(`${NMUX_BIN} kill`)}`], { stdio: 'ignore' });
}

function clickmapPathFor(paneId) {
  const safePaneId = String(paneId || 'default').replace(/[^A-Za-z0-9_%-]/g, '_');
  return path.join(CLICKMAP_DIR, `${safePaneId}.txt`);
}

// Append-only debug log for click events. The mouse binding now uses
// run-shell -b so errors thrown here would be swallowed silently — a
// "stuck" click would look identical to a successful one to the user.
// The log lets us reconstruct what happened post-hoc by timestamp.
// Capped at ~256 KiB; older content is dropped on rotation so the file
// never grows unbounded on long-running sessions.
const CLICK_LOG = path.join(CONFIG_DIR, 'click.log');
const CLICK_LOG_MAX_BYTES = 256 * 1024;
function logClick(msg) {
  try {
    fs.mkdirSync(CONFIG_DIR, { recursive: true });
    try {
      const st = fs.statSync(CLICK_LOG);
      if (st.size > CLICK_LOG_MAX_BYTES) {
        const tail = fs.readFileSync(CLICK_LOG).slice(-CLICK_LOG_MAX_BYTES / 2);
        fs.writeFileSync(CLICK_LOG, tail);
      }
    } catch {}
    fs.appendFileSync(CLICK_LOG, `${new Date().toISOString()} pid=${process.pid} ${msg}\n`);
  } catch {}
}

function clickHandler(rowStr, colStr, paneId) {
  const row = parseInt(rowStr, 10);
  const col = parseInt(colStr, 10) || 0;
  if (!Number.isFinite(row)) { logClick(`bad-row row=${rowStr} col=${colStr} pane=${paneId}`); return; }
  // Per-pane clickmap so a click in pane A is never resolved against
  // pane B's stale rows. tmux passes #{pane_id} into the binding.
  const cmFile = clickmapPathFor(paneId);
  if (!fs.existsSync(cmFile)) {
    logClick(`no-clickmap row=${row} col=${col} pane=${paneId} file=${cmFile}`);
    return;
  }
  const cmStat = fs.statSync(cmFile);
  const lines = fs.readFileSync(cmFile, 'utf8').split('\n');
  // Each entry: row<TAB>action<TAB>arg<TAB>colMin
  // Pick the entry with the highest colMin <= col on the matching row.
  let best = null;
  for (const line of lines) {
    if (!line) continue;
    const parts = line.split('\t');
    const r = parseInt(parts[0], 10);
    if (r !== row) continue;
    const colMin = parseInt(parts[3] || '0', 10);
    if (col < colMin) continue;
    if (!best || colMin > best.colMin) best = { action: parts[1], arg: parts[2] || '', colMin };
  }
  if (!best) {
    const cmAgeMs = Date.now() - cmStat.mtimeMs;
    logClick(`no-match row=${row} col=${col} pane=${paneId} clickmap_age_ms=${cmAgeMs} lines=${lines.length}`);
    return;
  }
  logClick(`dispatch action=${best.action} arg=${best.arg} row=${row} col=${col} pane=${paneId}`);
  try {
    switch (best.action) {
      case 'switch': {
        const target = `${SESSION}:${best.arg}`;
        // Mark the click so the watcher daemon ignores PTY redraw noise
        // for a few seconds. tmux's select-window / select-pane below
        // causes the pane to repaint, which bumps the PTY's mtime once
        // — without this marker the watcher would read that as fresh
        // agent activity and flip the row to "running" the moment the
        // user clicked. The marker is a wall-clock ms timestamp.
        spawnSync('tmux', ['set-window-option', '-t', target,
          '@nmuxlinux_clicked_at', String(Date.now())], { stdio: 'ignore' });
        if (process.env.TMUX) {
          const r = spawnSync('tmux', ['select-window', '-t', target], { encoding: 'utf8' });
          logClick(`switch select-window target=${target} rc=${r.status} stderr=${(r.stderr || '').trim().slice(0, 200)}`);
        } else {
          const r = spawnSync('tmux', ['switch-client', '-t', target], { encoding: 'utf8' });
          logClick(`switch switch-client target=${target} rc=${r.status} stderr=${(r.stderr || '').trim().slice(0, 200)}`);
        }
        focusMainPane(target);
        clearStatusTarget(target);
        break;
      }
      case 'close':
        closeWindow(best.arg);
        logClick(`close-window arg=${best.arg}`);
        break;
      case 'reopen':
        try { openProject(best.arg); }
        catch (e) { logClick(`reopen-error arg=${best.arg} err=${(e.message || e).slice(0, 200)}`); console.error(e.message); }
        break;
      case 'add':
        promptCommand();
        break;
      case 'kill':
        confirmKill();
        break;
    }
  } catch (e) {
    logClick(`dispatch-throw action=${best.action} err=${(e.message || e).slice(0, 200)}`);
  }
}

// Wrap-aware URL launcher for double-clicks in non-sidebar panes.
// tmux's stock select-word stops at visual-line boundaries, so a URL
// that wraps onto two rows is split — clicking either half copies
// only that fragment. Here we capture the pane in two ways:
//   - capture-pane -p   → visual lines (what the user sees)
//   - capture-pane -J -p → logical lines with wrap collapsed
// We extract every URL from the logical view, then check which one
// has a substring on the clicked visual row. The matched URL is the
// full thing, regardless of how many rows it wrapped across.
function clickUrlAtPane(paneId, yStr) {
  const Y = parseInt(yStr, 10);
  if (!paneId || !Number.isFinite(Y)) return;
  const visualRes = spawnSync('tmux', ['capture-pane', '-p', '-t', paneId], { encoding: 'utf8' });
  const logicalRes = spawnSync('tmux', ['capture-pane', '-J', '-p', '-t', paneId], { encoding: 'utf8' });
  if (visualRes.status !== 0 || logicalRes.status !== 0) {
    logClick(`url capture-fail pane=${paneId} y=${Y}`); return;
  }
  // URL regex: tolerant of common URL chars, stops at whitespace and a
  // few obvious sentence terminators. Trailing punctuation (.,;:) is
  // trimmed since URLs in prose often end with them.
  const URL_RE = /https?:\/\/[^\s<>"'`{}|\\^]+/g;
  const trimTrailing = u => u.replace(/[.,;:!?)\]]+$/, '');
  const urls = Array.from(new Set(
    [...logicalRes.stdout.matchAll(URL_RE)].map(m => trimTrailing(m[0]))
  )).filter(u => u.length >= 8);
  if (!urls.length) { logClick(`url no-urls-in-pane pane=${paneId} y=${Y}`); return; }
  const lines = visualRes.stdout.split('\n');
  const lineY = lines[Y] || '';
  if (!lineY) { logClick(`url empty-line pane=${paneId} y=${Y}`); return; }
  // Find the URL that has the longest substring overlap with the clicked
  // visual row. Prefer full-string matches; fall back to longest prefix
  // (URL was wrapped — the head sits on this row) or longest suffix
  // (the tail sits on this row).
  let best = null, bestLen = 0;
  for (const url of urls) {
    if (lineY.includes(url) && url.length > bestLen) { best = url; bestLen = url.length; continue; }
    for (let len = Math.min(url.length, lineY.length); len >= 8; len--) {
      const pre = url.slice(0, len);
      if (lineY.includes(pre)) { if (url.length > bestLen) { best = url; bestLen = url.length; } break; }
      const suf = url.slice(-len);
      if (lineY.includes(suf)) { if (url.length > bestLen) { best = url; bestLen = url.length; } break; }
    }
  }
  if (!best) { logClick(`url no-match pane=${paneId} y=${Y} line="${lineY.slice(0, 80)}"`); return; }
  logClick(`url launch pane=${paneId} y=${Y} url=${best.slice(0, 200)}`);
  if (which('xdg-open')) {
    spawnSync('xdg-open', [best], { detached: true, stdio: 'ignore' });
  }
  // Also stash on the clipboard — if xdg-open is missing or the URL
  // routes to the wrong handler, the user can still paste it.
  if (which('wl-copy')) {
    spawnSync('wl-copy', [], { input: best,
      env: { ...process.env,
             XDG_RUNTIME_DIR: process.env.XDG_RUNTIME_DIR || `/run/user/${process.getuid()}`,
             WAYLAND_DISPLAY: process.env.WAYLAND_DISPLAY || 'wayland-0' } });
  }
}

// ----- right-top: multi-agent task overlay -----
//
// Renders the active agent's task/plan list to the pane. Multiple
// coding agents are supported — each writes tasks in its own format
// and location, so we probe every known source and pick whichever
// one has the freshest mtime AND non-empty content. That way the
// pane tracks whichever agent the user is actually driving in this
// project, not just Claude.
//
// Source map (newer mtime wins):
//   1. Claude Code   — ~/.claude/tasks/<session>/<n>.json
//                      (global newest session; Claude doesn't bind
//                      sessions to cwd so we trust mtime)
//   2. opencode      — ~/.config/opencode/tasks/<basename(cwd)>/T-*.json
//   3. omx (codex)   — <cwd>/.omx/state/sessions/<newest>/ralph-state.json
//                      (completion_audit.prompt_to_artifact_checklist
//                      or implemented[])
//   4. TODO.md       — <cwd>/{TODO,TASKS,ROADMAP}.md (markdown
//                      checkboxes)
// Each source returns { source, tasks[], mtime }. Updates every 2s,
// alt-screen so wheel-scroll won't expose stale frames, read-only.
const CLAUDE_PROJECTS_DIR = path.join(HOME, '.claude', 'projects');
const OPENCODE_TASKS_DIR = path.join(HOME, '.config', 'opencode', 'tasks');
const TASK_OVERLAY_TICK_MS = 2000;

// Encode a cwd the way Claude Code names its project slugs: any `/`
// or `.` becomes `-`. Anchor with a leading `-` so it matches the
// directory naming on disk (e.g. /home/user/projects/example →
// -home-user-projects-example).
function claudeSlugFor(cwd) {
  if (!cwd) return null;
  return cwd.replace(/[\/.]/g, '-');
}

function safeStat(p) {
  try { return fs.statSync(p); } catch { return null; }
}
function safeReaddir(p) {
  try { return fs.readdirSync(p); } catch { return []; }
}
function newestEntry(parent) {
  const entries = safeReaddir(parent)
    .map(name => {
      const st = safeStat(path.join(parent, name));
      return st ? { name, mtime: st.mtimeMs } : null;
    })
    .filter(Boolean)
    .sort((a, b) => b.mtime - a.mtime);
  return entries[0] || null;
}

// --- Claude source ---
// Claude Code 2.x stores tasks inline in the session JSONL
// transcript at ~/.claude/projects/<slug>/<session>.jsonl. Each
// TaskCreate emits a tool_result whose `toolUseResult.task` carries
// {id, subject}; subsequent TaskUpdate calls carry {taskId, status}
// in their input. We scan the file for both patterns to reconstruct
// the current task list. Per-cwd: prefer the slug matching the pane
// directory, fall back to the most-recently-modified jsonl across
// all projects (covers the case where the pane is in a subdir of
// where claude was launched).
const _claudeJsonlCache = new Map(); // path → { size, tasks }
function parseClaudeJsonl(filePath, stat) {
  const cached = _claudeJsonlCache.get(filePath);
  if (cached && cached.size === stat.size) return cached.tasks;
  let text;
  try { text = fs.readFileSync(filePath, 'utf8'); } catch { return []; }
  // Two regex passes — task creations seed the map, then updates
  // mutate status. JSONL is append-only so textual order is
  // chronological.
  const tasks = new Map();
  const createRe = /"toolUseResult":\{"task":\{"id":"([^"]+)","subject":"((?:[^"\\]|\\.)*)"/g;
  let m;
  while ((m = createRe.exec(text)) !== null) {
    let subject;
    try { subject = JSON.parse('"' + m[2] + '"'); } catch { subject = m[2]; }
    tasks.set(m[1], { id: m[1], subject, status: 'pending' });
  }
  const updateRe = /"name":"TaskUpdate","input":\{[^}]+\}/g;
  while ((m = updateRe.exec(text)) !== null) {
    const block = m[0];
    const idMatch = /"taskId":"([^"]+)"/.exec(block);
    const stMatch = /"status":"([^"]+)"/.exec(block);
    if (idMatch && stMatch && tasks.has(idMatch[1])) {
      tasks.get(idMatch[1]).status = stMatch[1];
    }
  }
  const list = Array.from(tasks.values()).sort((a, b) => {
    const an = Number(a.id), bn = Number(b.id);
    if (Number.isFinite(an) && Number.isFinite(bn)) return an - bn;
    return a.id.localeCompare(b.id);
  });
  _claudeJsonlCache.set(filePath, { size: stat.size, tasks: list });
  return list;
}

function readClaudeSource(cwd, excl) {
  // Project-scoped: only look at JSONLs whose slug matches this
  // pane's cwd. Globbing across all slugs would let one busy session
  // (e.g. claude launched in /home/user/projects) hijack every
  // project pane.
  //
  // Parent-dir fallback: claude is often launched one or two levels
  // above the project root (e.g. /home/user/projects covers many
  // sub-projects). Walk up to HOME, stopping early. To avoid the
  // hijack problem, parent-dir JSONLs only count if their tasks
  // actually run in cwd — we check by streaming a recent slice for
  // a "cwd":"<cwd>" needle, and only accept if matched.
  if (!cwd) return null;
  const probeDirs = [cwd];
  let p = path.dirname(cwd);
  // Walk up at most 3 parents (cwd, parent, grandparent, ggparent).
  for (let i = 0; i < 3 && p && p !== '/' && p !== HOME; i++) {
    probeDirs.push(p);
    p = path.dirname(p);
  }
  const seen = new Set();
  for (let idx = 0; idx < probeDirs.length; idx++) {
    const probeCwd = probeDirs[idx];
    const slug = claudeSlugFor(probeCwd);
    if (seen.has(slug)) continue;
    seen.add(slug);
    const dir = path.join(CLAUDE_PROJECTS_DIR, slug);
    const candidates = [];
    for (const f of safeReaddir(dir)) {
      if (!/\.jsonl$/.test(f)) continue;
      const fp = path.join(dir, f);
      const st = safeStat(fp);
      if (st) candidates.push({ path: fp, mtime: st.mtimeMs, stat: st });
    }
    if (!candidates.length) continue;
    candidates.sort((a, b) => b.mtime - a.mtime);
    for (const c of candidates) {
      // Skip jsonls held open by the sub pane: those are another
      // agent's session, not ours.
      if (excl && excl.paths && excl.paths.has(c.path)) continue;
      // Parent slugs must prove relevance: at least one recent event
      // in the file must report cwd == pane cwd. Otherwise we'd pull
      // unrelated subprojects' tasks into this pane.
      if (idx > 0 && !jsonlMentionsCwd(c.path, cwd)) continue;
      const tasks = parseClaudeJsonl(c.path, c.stat);
      if (tasks.length) {
        const sessionId = path.basename(c.path, '.jsonl');
        return {
          source: `Claude · ${sessionId.slice(0, 8)}`,
          tasks,
          mtime: c.mtime,
        };
      }
    }
  }
  return null;
}

// Cheap relevance check: read only the tail of the JSONL (last
// ~200KB is plenty for any recent activity) and look for the cwd
// literal. Avoids loading 50MB transcripts just to discover the
// session isn't actually working in this dir.
function jsonlMentionsCwd(filePath, cwd) {
  try {
    const fd = fs.openSync(filePath, 'r');
    try {
      const st = fs.fstatSync(fd);
      const TAIL = 200 * 1024;
      const len = Math.min(TAIL, st.size);
      const buf = Buffer.alloc(len);
      fs.readSync(fd, buf, 0, len, Math.max(0, st.size - len));
      const needle = `"cwd":"${cwd}"`;
      return buf.indexOf(needle) !== -1;
    } finally { fs.closeSync(fd); }
  } catch { return false; }
}

// --- opencode source ---
// opencode stores per-project task json under
// ~/.config/opencode/tasks/<project>/T-*.json. The project key is
// the basename of cwd, so multi-project users get isolated lists.
function readOpencodeSource(cwd, excl) {
  if (!cwd) return null;
  // Sub-pane opencode running in this cwd shares the same per-project
  // task dir (keyed by basename), so silence the source rather than
  // try to disambiguate per-file.
  if (excl && excl.opencodeCwds && excl.opencodeCwds.has(cwd)) return null;
  const key = path.basename(cwd);
  if (!key) return null;
  const dir = path.join(OPENCODE_TASKS_DIR, key);
  const files = safeReaddir(dir).filter(f => /^T-.+\.json$/.test(f));
  if (!files.length) return null;
  const items = [];
  let mtime = 0;
  for (const f of files) {
    const fp = path.join(dir, f);
    if (excl && excl.paths && excl.paths.has(fp)) continue;
    const st = safeStat(fp);
    if (st && st.mtimeMs > mtime) mtime = st.mtimeMs;
    try {
      const j = JSON.parse(fs.readFileSync(fp, 'utf8'));
      if (j && j.subject) items.push({
        status: j.status || 'pending',
        subject: j.subject,
        _mtime: st ? st.mtimeMs : 0,
      });
    } catch {}
  }
  if (!items.length) return null;
  // opencode task files are immutable per-id; show in chronological
  // creation order so the user sees the plan as it was assembled.
  items.sort((a, b) => a._mtime - b._mtime);
  return { source: `opencode · ${key}`, tasks: items, mtime };
}

// --- codex source ---
// codex (openai/codex) writes a session rollout to
// ~/.codex/sessions/YYYY/MM/DD/rollout-*.jsonl. The first line is a
// session_meta with {cwd}. Every plan update is a function_call with
// name="update_plan" and arguments containing {plan:[{step,status}]}.
// The latest update_plan completely replaces the prior one, so we
// only need the last occurrence to render the current state.
const CODEX_SESSIONS_DIR = path.join(HOME, '.codex', 'sessions');
const CODEX_ROLLOUT_AGE_MS = 24 * 3600 * 1000; // ignore rollouts older than a day
const _codexRolloutCache = new Map(); // path → { size, plan, plannedAt }

const _codexCandidateCache = { at: 0, candidates: [] };
const CODEX_CANDIDATE_SCAN_TTL_MS = 30000;

function codexDateDirParts(d) {
  const y = String(d.getFullYear()).padStart(4, '0');
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return [y, m, day];
}

function recentCodexSessionDirs(now = Date.now()) {
  // Codex stores sessions under YYYY/MM/DD. Scan only recent calendar
  // days instead of walking the entire historical tree every overlay tick.
  // Include a 3-day window to cover timezone edges and long overnight runs.
  const dirs = new Set();
  for (let back = 0; back < 3; back++) {
    const d = new Date(now - back * 24 * 3600 * 1000);
    const [y, m, day] = codexDateDirParts(d);
    dirs.add(path.join(CODEX_SESSIONS_DIR, y, m, day));
  }
  return Array.from(dirs);
}

function recentCodexRolloutCandidates(now = Date.now()) {
  if (now - _codexCandidateCache.at < CODEX_CANDIDATE_SCAN_TTL_MS) {
    return _codexCandidateCache.candidates;
  }
  const candidates = [];
  for (const dyDir of recentCodexSessionDirs(now)) {
    for (const f of safeReaddir(dyDir)) {
      if (!/^rollout-.+\.jsonl$/.test(f)) continue;
      const fp = path.join(dyDir, f);
      const st = safeStat(fp);
      if (!st) continue;
      if (now - st.mtimeMs > CODEX_ROLLOUT_AGE_MS) continue;
      candidates.push({ path: fp, mtime: st.mtimeMs, stat: st });
    }
  }
  _codexCandidateCache.at = now;
  _codexCandidateCache.candidates = candidates;
  return candidates;
}

function codexFirstLineCwd(filePath) {
  try {
    const fd = fs.openSync(filePath, 'r');
    try {
      const buf = Buffer.alloc(8192);
      const n = fs.readSync(fd, buf, 0, buf.length, 0);
      const head = buf.slice(0, n).toString('utf8');
      const nl = head.indexOf('\n');
      const line = nl === -1 ? head : head.slice(0, nl);
      const j = JSON.parse(line);
      return j?.payload?.cwd || null;
    } finally { fs.closeSync(fd); }
  } catch { return null; }
}

function parseCodexPlan(filePath, stat) {
  const cached = _codexRolloutCache.get(filePath);
  if (cached && cached.size === stat.size) return cached;
  let text;
  try { text = fs.readFileSync(filePath, 'utf8'); } catch { return null; }
  // Merge EVERY update_plan call rather than only the last one.
  // codex rewrites the plan in full on each tick, so steps that
  // were already completed sometimes disappear from later plans —
  // without merging we'd lose history. Each plan entry is preceded
  // by its rollout timestamp, so we can pair them by walking
  // sequentially.
  const lineRe = /\{"timestamp":"([^"]+)"[^\n]*?"name":"update_plan","arguments":"((?:[^"\\]|\\.)*?)"[^\n]*\}/g;
  const merged = new Map(); // step text → { status, firstSeen, lastSeen, statusChangedAt, order }
  let order = 0;
  let m;
  while ((m = lineRe.exec(text)) !== null) {
    const ts = m[1];
    let parsed;
    try {
      const argStr = JSON.parse('"' + m[2] + '"');
      parsed = JSON.parse(argStr);
    } catch { continue; }
    if (!parsed || !Array.isArray(parsed.plan)) continue;
    for (const p of parsed.plan) {
      const subject = String(p.step || p.subject || '').trim();
      if (!subject) continue;
      const status = p.status === 'completed' ? 'completed'
                   : p.status === 'in_progress' ? 'in_progress'
                   : p.status === 'failed' ? 'failed' : 'pending';
      const prev = merged.get(subject);
      if (!prev) {
        merged.set(subject, {
          subject, status,
          firstSeen: ts, lastSeen: ts,
          statusChangedAt: ts,
          order: order++,
        });
      } else {
        const statusChanged = prev.status !== status;
        prev.lastSeen = ts;
        if (statusChanged) {
          prev.status = status;
          prev.statusChangedAt = ts;
        }
      }
    }
  }
  if (!merged.size) {
    _codexRolloutCache.set(filePath, { size: stat.size, plan: null });
    return null;
  }
  const tasks = Array.from(merged.values());
  const entry = { size: stat.size, plan: tasks };
  _codexRolloutCache.set(filePath, entry);
  return entry;
}

function readCodexSource(cwd, excl) {
  if (!cwd) return null;
  const now = Date.now();
  const candidates = recentCodexRolloutCandidates(now);
  // Pre-filter by first-line cwd. Cache the cwd lookup by path: it
  // never changes after the file is created, so this is cheap.
  const matching = [];
  for (const c of candidates) {
    let rcwd = _codexCwdCache.get(c.path);
    if (rcwd === undefined) {
      rcwd = codexFirstLineCwd(c.path);
      _codexCwdCache.set(c.path, rcwd);
    }
    if (rcwd === cwd) matching.push(c);
  }
  // Drop any rollout currently held open by the sub pane.
  const filtered = matching.filter(c => !(excl && excl.paths && excl.paths.has(c.path)));
  if (!filtered.length) return null;
  filtered.sort((a, b) => b.mtime - a.mtime);
  const pick = filtered[0];
  const parsed = parseCodexPlan(pick.path, pick.stat);
  if (!parsed || !parsed.plan || !parsed.plan.length) return null;
  const sid = path.basename(pick.path).replace(/^rollout-/, '').replace(/\.jsonl$/, '');
  // sid looks like "2026-05-23T11-27-40-<uuid>"; show the date stamp.
  const label = sid.slice(0, 19).replace(/-/g, (c, i) => i < 10 ? '-' : (i === 13 || i === 16 ? ':' : '-'));
  return {
    source: `codex · ${label}`,
    tasks: parsed.plan,
    mtime: pick.mtime,
  };
}
const _codexCwdCache = new Map();

// --- omx (oh-my-codex) source ---
// omx doesn't track discrete tasks during a run; the closest thing
// is the latest ralph-state.json in <cwd>/.omx/state/sessions/. It
// has `completion_audit.prompt_to_artifact_checklist[]` (post-run
// requirements + status) and `implemented[]` (free-text done list).
// We synthesize a task list from those, marking implemented items
// as completed. If the run is mid-flight (active=true) and there's
// no checklist yet, return null so a fresher source can take over.
function readOmxSource(cwd, excl) {
  if (!cwd) return null;
  // If the sub pane is running omx in this same cwd, suppress the
  // omx source entirely — its state file would otherwise win the
  // freshness race and the sub's progress would leak into status.
  if (excl && excl.omxCwds && excl.omxCwds.has(cwd)) return null;
  const sessionsDir = path.join(cwd, '.omx', 'state', 'sessions');
  const newest = newestEntry(sessionsDir);
  if (!newest) return null;
  const sessionDir = path.join(sessionsDir, newest.name);
  const ralphPath = path.join(sessionDir, 'ralph-state.json');
  if (excl && excl.paths && excl.paths.has(ralphPath)) return null;
  const st = safeStat(ralphPath);
  if (!st) return null;
  let j;
  try { j = JSON.parse(fs.readFileSync(ralphPath, 'utf8')); } catch { return null; }
  const tasks = [];
  const checklist = j?.completion_audit?.prompt_to_artifact_checklist;
  if (Array.isArray(checklist)) {
    for (const c of checklist) {
      if (typeof c === 'string') {
        // arrow-style "requirement -> artifact"; keep the requirement
        const sub = c.split('->')[0].trim() || c;
        tasks.push({ status: 'completed', subject: sub });
      } else if (c && typeof c === 'object' && c.requirement) {
        tasks.push({
          status: c.status === 'passed' ? 'completed'
                 : c.status === 'failed' ? 'failed' : 'pending',
          subject: String(c.requirement),
        });
      }
    }
  }
  if (!tasks.length && Array.isArray(j.implemented)) {
    for (const s of j.implemented) tasks.push({ status: 'completed', subject: String(s) });
  }
  if (j.fix && typeof j.fix === 'string') {
    tasks.push({ status: 'completed', subject: 'fix: ' + j.fix });
  }
  if (!tasks.length) return null;
  const label = j.release ? `omx · ${newest.name.slice(0, 14)} · ${j.release}`
                          : `omx · ${newest.name.slice(0, 14)}`;
  return { source: label, tasks, mtime: st.mtimeMs };
}

// --- TODO.md fallback ---
// Markdown checkbox idiom: "- [ ] foo" pending, "- [x] foo" done,
// "- [-] foo" / "- [/] foo" in-progress (extension some projects
// use). The first file found in TODO_CANDIDATES wins.
const TODO_CANDIDATES = [
  'TODO.md', 'TASKS.md', 'ROADMAP.md', 'TODO', 'TODOS.md',
  'todo.md', 'tasks.md', '.todo', 'docs/TODO.md', 'docs/TASKS.md',
];
function readTodoSource(cwd) {
  if (!cwd) return null;
  for (const name of TODO_CANDIDATES) {
    const fp = path.join(cwd, name);
    const st = safeStat(fp);
    if (!st) continue;
    let text;
    try { text = fs.readFileSync(fp, 'utf8'); } catch { continue; }
    const re = /^\s*[-*+]\s+\[([ xX/\-])\]\s+(.+)$/gm;
    const tasks = [];
    let m;
    while ((m = re.exec(text)) !== null) {
      const mark = m[1].toLowerCase();
      const status = mark === 'x' ? 'completed'
                   : (mark === '-' || mark === '/') ? 'in_progress'
                   : 'pending';
      tasks.push({ status, subject: m[2].trim() });
    }
    if (tasks.length) return { source: name, tasks, mtime: st.mtimeMs };
  }
  return null;
}

// Walk the sub pane's process tree and collect any open file paths
// that look like agent session storage. Anything an agent in the sub
// pane has open is implicitly *not* the main pane's work — we exclude
// these paths from the source pickers so sub-pane activity can never
// pollute the status overlay.
//
// For omx/opencode the agent doesn't keep a single session file open
// (it writes and closes), so fd inspection misses them. We also
// detect the agent by cmdline and tag its cwd; the source readers
// then check those cwd tags before returning.
//
// Returns { paths: Set<string>, omxCwds: Set<string>, opencodeCwds: Set<string> }.
function collectSubPaneSessions(statusPaneId) {
  const empty = { paths: new Set(), omxCwds: new Set(), opencodeCwds: new Set() };
  if (!statusPaneId) return empty;
  const winOut = spawnSync('tmux', ['display-message', '-p', '-t', statusPaneId,
    '#{session_name}:#{window_index}'], { encoding: 'utf8' });
  if (winOut.status !== 0) return empty;
  const winTarget = winOut.stdout.trim();
  const ls = spawnSync('tmux', ['list-panes', '-t', winTarget,
    '-F', '#{pane_id}\t#{pane_title}\t#{pane_pid}'], { encoding: 'utf8' });
  if (ls.status !== 0) return empty;
  const subRoots = [];
  for (const line of ls.stdout.trim().split('\n')) {
    const parts = line.split('\t');
    if (parts.length !== 3) continue;
    const [, title, panePid] = parts;
    if (paneRoleOf(title) !== 'sub') continue;
    const n = parseInt(panePid, 10);
    if (Number.isFinite(n)) subRoots.push(n);
  }
  if (!subRoots.length) return empty;
  const out = { paths: new Set(), omxCwds: new Set(), opencodeCwds: new Set() };
  for (const rootPid of subRoots) walkSubPaneTree(rootPid, out);
  return out;
}

function walkSubPaneTree(rootPid, out) {
  const visited = new Set();
  const stack = [rootPid];
  let safety = 256;
  while (stack.length && safety-- > 0) {
    const pid = stack.pop();
    if (visited.has(pid)) continue;
    visited.add(pid);
    // Enqueue children
    try {
      const taskDirs = fs.readdirSync(`/proc/${pid}/task`);
      for (const tid of taskDirs) {
        let kids;
        try { kids = fs.readFileSync(`/proc/${pid}/task/${tid}/children`, 'utf8'); }
        catch { continue; }
        for (const k of kids.trim().split(/\s+/)) {
          const kpid = parseInt(k, 10);
          if (Number.isFinite(kpid) && !visited.has(kpid)) stack.push(kpid);
        }
      }
    } catch { /* pid gone */ continue; }
    // Inspect open fds for known agent session files
    let fds = null;
    try { fds = fs.readdirSync(`/proc/${pid}/fd`); } catch {}
    if (fds) {
      for (const fd of fds) {
        let tgt;
        try { tgt = fs.readlinkSync(`/proc/${pid}/fd/${fd}`); } catch { continue; }
        if (!tgt) continue;
        if (tgt.includes('/.claude/projects/') && tgt.endsWith('.jsonl')) out.paths.add(tgt);
        else if (tgt.includes('/.codex/sessions/') && tgt.endsWith('.jsonl')) out.paths.add(tgt);
        else if (tgt.includes('/.omx/state/sessions/') && tgt.endsWith('ralph-state.json')) out.paths.add(tgt);
        else if (tgt.includes('/.config/opencode/tasks/') && /\/T-.+\.json$/.test(tgt)) out.paths.add(tgt);
      }
    }
    // Identify omx/opencode by cmdline so we can exclude their cwd
    // even when they aren't holding the session file open.
    let cmd = '';
    try { cmd = fs.readFileSync(`/proc/${pid}/cmdline`, 'utf8'); } catch { continue; }
    if (!cmd) continue;
    const args = cmd.split('\0').filter(Boolean);
    let kind = null;
    for (const a of args) {
      const base = a.split('/').pop();
      if (base === 'omx' || a.endsWith('/oh-my-codex') || a.includes('oh-my-codex/')) { kind = 'omx'; break; }
      if (base === 'opencode' || a.endsWith('/opencode')) { kind = 'opencode'; break; }
    }
    if (!kind) continue;
    let cwdp = null;
    try { cwdp = fs.readlinkSync(`/proc/${pid}/cwd`); } catch {}
    if (!cwdp) continue;
    if (kind === 'omx') out.omxCwds.add(cwdp);
    else if (kind === 'opencode') out.opencodeCwds.add(cwdp);
  }
}

// Probe every source and pick the freshest non-empty one. mtime
// alone is the tiebreaker — whatever agent has been writing most
// recently wins the pane. excl carries the sub-pane sessions to
// exclude so sub-pane activity never bleeds into the status overlay.
function pickActiveTaskSource(cwd, excl) {
  const probes = [
    readClaudeSource(cwd, excl),
    readCodexSource(cwd, excl),
    readOpencodeSource(cwd, excl),
    readOmxSource(cwd, excl),
    readTodoSource(cwd),
  ].filter(s => s && s.tasks && s.tasks.length);
  if (!probes.length) return null;
  probes.sort((a, b) => b.mtime - a.mtime);
  return probes[0];
}

function paintAltScreen(body) {
  // Synced update + cursor home + clear-from-cursor-down (wipes
  // the previous frame), then write the body. We deliberately do
  // NOT emit a trailing newline after the body — when body line
  // count equals pane height the trailing \n triggers a scroll
  // that pushes the top row off-screen.
  return '\x1b[?2026h\x1b[H\x1b[J' + body + '\x1b[?2026l';
}

// Per-pane event queue. tmux bindings on the right-top pane append
// "SCROLL UP" / "SCROLL DOWN" / "CLICK <y>" lines here; the running
// daemon polls the file each tick and applies them. Using a file
// instead of signals lets us carry parameters (which row was clicked,
// which direction) cleanly.
const TASK_EVENT_DIR = path.join(CONFIG_DIR, 'task-events');
function taskEventFile(paneId) {
  return path.join(TASK_EVENT_DIR, paneId.replace(/[^A-Za-z0-9_-]/g, '_') + '.queue');
}

// One row in the rendered overlay → which task it represents.
// Persisted to disk so the click handler (which runs as a separate
// nmux-linux process) can read it.
function taskRowmapFile(paneId) {
  return path.join(TASK_EVENT_DIR, paneId.replace(/[^A-Za-z0-9_-]/g, '_') + '.rowmap.json');
}

function appendTaskEvent(paneId, event) {
  try {
    fs.mkdirSync(TASK_EVENT_DIR, { recursive: true });
    fs.appendFileSync(taskEventFile(paneId), event + '\n');
  } catch {}
}

function readAndClearTaskEvents(paneId) {
  const fp = taskEventFile(paneId);
  let text;
  try { text = fs.readFileSync(fp, 'utf8'); } catch { return []; }
  try { fs.writeFileSync(fp, ''); } catch {}
  return text.split('\n').map(s => s.trim()).filter(Boolean);
}

// Resolve the "main coding pane" for a given window. Layout is
// sidebar | main | code-mid | right-top/right-bot, so the main is
// the pane whose title isn't reserved and which sits leftmost (after
// the sidebar). We pick by smallest pane_left coordinate.
function findMainPaneInWindow(windowTarget) {
  const out = spawnSync('tmux', ['list-panes', '-t', windowTarget,
    '-F', '#{pane_id}\t#{pane_title}\t#{pane_left}'], { encoding: 'utf8' });
  if (out.status !== 0) return null;
  const candidates = out.stdout.trim().split('\n')
    .map(l => l.split('\t'))
    .filter(p => p.length === 3 && !RESERVED_PANE_TITLES.has(p[1]))
    .map(([id, title, left]) => ({ id, title, left: parseInt(left, 10) }))
    .sort((a, b) => a.left - b.left);
  return candidates[0]?.id || null;
}

// Click on a status row should surface the corresponding task in
// the main pane. Two regimes:
//
//   - Main pane runs a TUI agent (claude/codex) on the alternate
//     screen. tmux's scrollback only captures the *primary* buffer,
//     so search-backward can never see the agent's view. For these
//     panes we open a tmux popup that surfaces the task text
//     directly, since the agent owns the screen.
//
//   - Main pane runs a normal shell with scrolling output (omx logs,
//     bash, etc). copy-mode + search-backward lands on the task
//     subject in the scrollback, which is what the user wants.
//
// We pick the regime by checking #{alternate_on} on the main pane.
function jumpMainPaneToTask(paneId, subject) {
  // Find the window that owns the right-top daemon pane.
  const winOut = spawnSync('tmux', ['display-message', '-p', '-t', paneId,
    '#{session_name}:#{window_index}'], { encoding: 'utf8' });
  if (winOut.status !== 0) return;
  const winTarget = winOut.stdout.trim();
  const mainPane = findMainPaneInWindow(winTarget);
  if (!mainPane) return;
  const altOut = spawnSync('tmux', ['display-message', '-p', '-t', mainPane,
    '#{alternate_on}'], { encoding: 'utf8' });
  const isAlt = altOut.status === 0 && altOut.stdout.trim() === '1';
  if (isAlt) {
    showTaskPopup(subject);
    return;
  }
  // Trim the subject to a reasonable search snippet — long Korean
  // sentences can include punctuation that tmux search treats
  // literally; keep the first ~40 chars to maximize hit rate.
  const snippet = String(subject).replace(/\s+/g, ' ').trim().slice(0, 40);
  if (!snippet) return;
  spawnSync('tmux', ['copy-mode', '-t', mainPane], { stdio: 'ignore' });
  spawnSync('tmux', ['send-keys', '-t', mainPane, '-X', 'search-backward', snippet],
    { stdio: 'ignore' });
}

// Pop a modal with the task subject. -E runs the command and closes
// the popup when it exits; `read -n 1` waits for any single keypress
// so the user can read at their pace. Detached so the daemon's tick
// loop keeps running while the popup is up.
function showTaskPopup(subject) {
  const body = String(subject || '').replace(/\r/g, '');
  const cmd =
    `printf '\\033[1;36m  Task\\033[0m\\n\\n  %s\\n\\n\\033[2m  (main pane이 TUI 모드라 scroll-jump 불가 — 아무 키나 눌러 닫기)\\033[0m\\n' ${shQuote(body)};` +
    ` read -n 1 -s _`;
  const child = spawn('tmux',
    ['display-popup', '-E', '-w', '70%', '-h', '30%', '-S', 'fg=colour39',
     'bash', '-lc', cmd],
    { detached: true, stdio: 'ignore' });
  child.unref();
}


function clipDisplayText(s, max) {
  const text = String(s || '').replace(/\s+/g, ' ').trim();
  if (!Number.isFinite(max) || max <= 0) return '';
  if (text.length <= max) return text;
  if (max <= 1) return text.slice(0, max);
  return text.slice(0, max - 1) + '…';
}

function statusKoreanLabel(status) {
  const s = String(status || 'idle').trim() || 'idle';
  const labels = {
    idle: '대기(idle)',
    running: '실행 중(running)',
    done: '완료(done)',
    failed: '실패(failed)',
    'need-input': '입력 필요(need-input)',
  };
  return labels[s] || s;
}

function statusColor(status) {
  const s = String(status || 'idle').trim();
  if (s === 'running') return '\x1b[33m';
  if (s === 'done') return '\x1b[32m';
  if (s === 'failed') return '\x1b[31m';
  if (s === 'need-input') return '\x1b[35m';
  return '\x1b[2m';
}

function agentNameFromCmdline(cmdline) {
  const c = normalizeCmdline(cmdline);
  if (!c) return '';
  const parts = c.split(/\s+/);
  if (!parts.length) return '';
  const arg0 = (parts[0] || '').split('/').pop();
  if (typeof AGENT_BINS !== 'undefined' && AGENT_BINS.has(arg0)) return arg0;
  if (arg0 === 'node' && parts.length >= 2) {
    const sub = (parts[1] || '').split('/').pop();
    if (typeof AGENT_BINS !== 'undefined' && AGENT_BINS.has(sub)) return sub;
  }
  return '';
}

function detectAgentNameInPane(rootPid) {
  if (!rootPid) return '';
  const proc = readProcIndex();
  const agents = findAgentPidsInPane(rootPid, proc);
  for (const pid of agents) {
    const name = agentNameFromCmdline(proc.commands.get(String(pid)));
    if (name) return name;
  }
  return '';
}

function taskOverlayStatusContext(paneId, cwd) {
  const base = {
    project: path.basename(cwd || process.cwd() || HOME) || 'project',
    status: 'idle',
    message: '',
    mainCommand: '',
    mainCwd: cwd || '',
    agent: '',
  };
  if (!paneId) return base;
  const out = spawnSync('tmux', ['display-message', '-p', '-t', paneId,
    '#{session_name}:#{window_index}\t#{@nmuxlinux_project}\t#{@nmuxlinux_status}\t#{@nmuxlinux_message}'],
    { encoding: 'utf8' });
  if (out.status !== 0) return base;
  const [winTarget, project, status, message] = out.stdout.trimEnd().split('\t');
  const ctx = {
    ...base,
    project: project || base.project,
    status: status || 'idle',
    message: message || '',
  };
  if (!winTarget) return ctx;
  const mainPane = findMainPaneInWindow(winTarget);
  if (!mainPane) return ctx;
  const minfo = spawnSync('tmux', ['display-message', '-p', '-t', mainPane,
    '#{pane_current_command}\t#{pane_current_path}\t#{pane_pid}'], { encoding: 'utf8' });
  if (minfo.status !== 0) return ctx;
  const [cmd, mainCwd, rootPid] = minfo.stdout.trimEnd().split('\t');
  ctx.mainCommand = cmd || '';
  ctx.mainCwd = mainCwd || ctx.mainCwd;
  // Full process-tree agent detection is useful but expensive when every
  // status pane performs it. Keep the overlay cheap by default; operators
  // can enable the deeper lookup temporarily for debugging.
  if (process.env.NMUX_TASK_OVERLAY_DETECT_AGENT === '1') {
    ctx.agent = detectAgentNameInPane(rootPid);
  }
  return ctx;
}

function renderTaskOverlaySummaryLines(ctx, sourceLabel, w) {
  const width = Math.max(20, Number(w) || 60);
  const lines = [];
  const project = clipDisplayText(ctx.project || 'project', Math.max(8, width - 14));
  const src = sourceLabel && sourceLabel !== '(no source)' ? sourceLabel : '없음';
  const status = String(ctx.status || 'idle');
  lines.push(`\x1b[1;38;5;39m  상태판\x1b[0m  \x1b[2m· ${project}\x1b[0m`);
  lines.push('\x1b[2m' + '─'.repeat(Math.min(width - 1, 60)) + '\x1b[0m');
  lines.push(` \x1b[1m상태\x1b[0m  ${statusColor(status)}${statusKoreanLabel(status)}\x1b[0m`);
  if (ctx.message) {
    lines.push(` \x1b[1m메시지\x1b[0m  ${clipDisplayText(ctx.message, Math.max(8, width - 10))}`);
  }
  lines.push(` \x1b[1m작업 소스\x1b[0m  ${clipDisplayText(src, Math.max(8, width - 13))}`);
  const main = ctx.agent ? `agent:${ctx.agent}` : (ctx.mainCommand || 'shell');
  lines.push(` \x1b[1m메인 pane\x1b[0m  ${clipDisplayText(main, Math.max(8, width - 13))}`);
  return lines;
}

function renderNoTaskFallbackLines(ctx, sourceLabel, w) {
  const width = Math.max(20, Number(w) || 60);
  const lines = [];
  lines.push('');
  lines.push(' \x1b[1m작업 목록\x1b[0m  없음');
  if (sourceLabel && sourceLabel !== '(no source)') {
    lines.push(` \x1b[2m${clipDisplayText(sourceLabel, Math.max(8, width - 3))}에 열린 작업이 없습니다\x1b[0m`);
  } else {
    lines.push(' \x1b[2mTODO.md / Claude / Codex / omx 작업 파일 없음\x1b[0m');
  }
  if (ctx.mainCwd) {
    lines.push(` \x1b[2mcwd · ${clipDisplayText(ctx.mainCwd, Math.max(8, width - 8))}\x1b[0m`);
  }
  return lines;
}

function taskOverlayDaemon(cwd) {
  cwd = cwd || process.env.PWD || process.cwd();
  const paneId = process.env.TMUX_PANE || '';
  // Per-pane clear-history so wheel-scroll on this pane shows the
  // current frame, not earlier paints. Same trick as the sidebar.
  if (paneId) {
    spawnSync('tmux', ['clear-history', '-t', paneId], { stdio: 'ignore' });
  }
  // Wipe any leftover events from a previous daemon instance so we
  // don't replay stale scroll/click on startup.
  if (paneId) {
    try { fs.mkdirSync(TASK_EVENT_DIR, { recursive: true }); } catch {}
    try { fs.writeFileSync(taskEventFile(paneId), ''); } catch {}
  }
  process.stdout.write('\x1b[?1049h');
  let lastBody = null;
  let viewportBottom = -1;       // index of last-rendered task; -1 = follow latest
  let autoFollow = true;         // if true, viewport sticks to the newest task
  let lastSortedRef = null;      // last rendered list (for click resolution)
  let sourceCache = { at: 0, picked: null, excl: null };
  let ctxCache = { at: 0, ctx: null };
  const SOURCE_SCAN_MS = Math.max(5000, Number(process.env.NMUX_TASK_SOURCE_SCAN_MS || 15000));
  const CONTEXT_SCAN_MS = Math.max(3000, Number(process.env.NMUX_TASK_CONTEXT_SCAN_MS || 10000));

  function applyEvents() {
    if (!paneId) return;
    const events = readAndClearTaskEvents(paneId);
    if (!events.length) return;
    for (const e of events) {
      if (e === 'SCROLL UP') {
        // see older — viewport bottom moves up by 1
        autoFollow = false;
        if (viewportBottom > 0) viewportBottom--;
      } else if (e === 'SCROLL DOWN') {
        // see newer — viewport bottom moves down by 1; re-engage
        // follow-mode when we reach the latest item.
        viewportBottom++;
      } else if (e === 'SCROLL TOP') {
        autoFollow = false;
        viewportBottom = 0;
      } else if (e === 'SCROLL BOTTOM') {
        autoFollow = true;
        viewportBottom = -1;
      } else if (e.startsWith('CLICK ')) {
        const y = parseInt(e.slice(6), 10);
        if (Number.isFinite(y) && lastSortedRef && lastSortedRef.rowMap) {
          const subject = lastSortedRef.rowMap.get(y);
          if (subject) jumpMainPaneToTask(paneId, subject);
        }
      }
    }
  }

  function render() {
    const w = process.stdout.columns || 60;
    // Walk the sub pane's process tree each tick and feed the open
    // agent files / claimed cwds to the source pickers as an exclude
    // set. This is the guarantee that whatever the user runs in the
    // sub pane stays out of the status overlay.
    const now = Date.now();
    if (!sourceCache.excl || now - sourceCache.at >= SOURCE_SCAN_MS) {
      const excl = collectSubPaneSessions(paneId);
      sourceCache = { at: now, excl, picked: pickActiveTaskSource(cwd, excl) };
    }
    if (!ctxCache.ctx || now - ctxCache.at >= CONTEXT_SCAN_MS) {
      ctxCache = { at: now, ctx: taskOverlayStatusContext(paneId, cwd) };
    }
    const picked = sourceCache.picked;
    const tasks = picked ? picked.tasks : [];
    const sourceLabel = picked ? picked.source : '(no source)';
    const ctx = ctxCache.ctx;
    const lines = renderTaskOverlaySummaryLines(ctx, sourceLabel, w);
    if (!tasks.length) {
      lines.push(...renderNoTaskFallbackLines(ctx, sourceLabel, w));
      lastSortedRef = { rowMap: new Map() };
    } else {
      // Two-bucket stack: completed [x] above, todo [ ] below.
      // Within each bucket, oldest at top → newest at bottom. This
      // matches the agent's working pattern (codex rewrites the
      // plan on each tick, so freshly-added items often appear with
      // pre-existing completed ones — separating by status keeps
      // the visual unambiguous).
      let done = 0, todo = 0;
      for (const t of tasks) {
        if (t.status === 'completed') done++; else todo++;
      }
      lines.push(` \x1b[32m[x] ${done}\x1b[0m   \x1b[2m[ ] ${todo}\x1b[0m   \x1b[2m(${done}/${tasks.length})\x1b[0m`);
      lines.push('');
      const completed = tasks.filter(t => t.status === 'completed');
      const open = tasks.filter(t => t.status !== 'completed');
      const tsOf = t => t.statusChangedAt || t.lastSeen || '';
      completed.sort((a, b) => {
        const at = tsOf(a), bt = tsOf(b);
        if (at && bt && at !== bt) return at < bt ? -1 : 1;
        return (a.order ?? 0) - (b.order ?? 0);
      });
      open.sort((a, b) => {
        // open items don't have a meaningful statusChangedAt — they
        // never transitioned — so fall back to first-seen order.
        const at = a.firstSeen || '', bt = b.firstSeen || '';
        if (at && bt && at !== bt) return at < bt ? -1 : 1;
        return (a.order ?? 0) - (b.order ?? 0);
      });
      const ordered = completed.concat(open);
      const h = process.stdout.rows || 24;
      const reserveTop = 1, reserveBottom = 1;
      const budget = Math.max(1, h - lines.length - reserveTop - reserveBottom);
      // viewportBottom = index of the LAST task to render. Default
      // is bottom-anchored (latest). When the user scrolls back to
      // the bottom we re-engage auto-follow so future task additions
      // stay visible automatically.
      if (viewportBottom < 0 || autoFollow) {
        viewportBottom = ordered.length - 1;
      }
      if (viewportBottom >= ordered.length - 1) {
        viewportBottom = ordered.length - 1;
        autoFollow = true;
      }
      if (viewportBottom < budget - 1) viewportBottom = Math.min(ordered.length - 1, budget - 1);
      const start = Math.max(0, viewportBottom - budget + 1);
      const visible = ordered.slice(start, viewportBottom + 1);
      const aboveCount = start;
      const belowCount = ordered.length - 1 - viewportBottom;
      // Top hint: hidden older items (scroll up to see).
      if (aboveCount > 0) {
        lines.push(`\x1b[2m   ↑ +${aboveCount} 이전 (wheel ↑)\x1b[0m`);
      } else {
        lines.push('');
      }
      const rowMap = new Map();
      for (const t of visible) {
        const checked = t.status === 'completed';
        const icon = checked ? '\x1b[32m[x]\x1b[0m' : '\x1b[2m[ ]\x1b[0m';
        const sub = String(t.subject || t.activeForm || '').replace(/\s+/g, ' ').trim();
        const text = sub.slice(0, w - 6);
        const style = checked ? '\x1b[2m' : '';
        const close = style ? '\x1b[0m' : '';
        const row1 = lines.length + 1;
        rowMap.set(row1, sub);
        lines.push(` ${icon} ${style}${text}${close}`);
      }
      if (belowCount > 0) {
        lines.push(`\x1b[2m   ↓ +${belowCount} 최신 (wheel ↓)\x1b[0m`);
      }
      lastSortedRef = { rowMap };
    }
    const body = lines.map(l => l + '\x1b[K').join('\n');
    if (body !== lastBody) {
      process.stdout.write(paintAltScreen(body));
      lastBody = body;
    }
  }
  function tick() {
    applyEvents();
    render();
  }
  tick();
  // Local performance patch: the old 200ms loop was too aggressive.
  // It repeatedly walks process trees and task sources; with several open
  // projects this saturated CPU and made Codex/OMX appear stuck at Working.
  // Default to 10s; allow temporary override for debugging.
  const TASK_OVERLAY_TICK_MS = Math.max(3000, Number(process.env.NMUX_TASK_OVERLAY_TICK_MS || 10000));
  const timer = setInterval(tick, TASK_OVERLAY_TICK_MS);
  function exit() {
    try { process.stdout.write('\x1b[?1049l'); } catch {}
    clearInterval(timer);
    process.exit(0);
  }
  process.on('SIGTERM', exit);
  process.on('SIGINT', exit);
}

// ----- right-bot: git status overlay -----
//
// Branch + ahead/behind + short status + last few commits. cwd is
// passed in as --cwd by the buildLayout caller so the helper points
// at the project root even when the pane was spawned from a deeper
// directory.
const GIT_OVERLAY_TICK_MS = 3000;

function git(cwd, args) {
  const r = spawnSync('git', ['-C', cwd, ...args], { encoding: 'utf8' });
  return r.status === 0 ? r.stdout : '';
}

function gitOverlayDaemon(cwd) {
  const dir = cwd || process.env.PWD || process.cwd() || HOME;
  if (process.env.TMUX_PANE) {
    spawnSync('tmux', ['clear-history', '-t', process.env.TMUX_PANE], { stdio: 'ignore' });
  }
  process.stdout.write('\x1b[?1049h');
  let lastBody = null;
  function render() {
    const w = process.stdout.columns || 60;
    const lines = [];
    lines.push('\x1b[1;38;5;208m  git · ' + path.basename(dir) + '\x1b[0m');
    lines.push('\x1b[2m' + '─'.repeat(Math.min(w - 1, 60)) + '\x1b[0m');
    // Bail early if not a git repo.
    const insideOut = spawnSync('git', ['-C', dir, 'rev-parse', '--is-inside-work-tree'],
      { encoding: 'utf8' });
    if (insideOut.status !== 0) {
      lines.push(' \x1b[2m(not a git repository)\x1b[0m');
    } else {
      const branch = git(dir, ['symbolic-ref', '--short', 'HEAD']).trim() ||
                     git(dir, ['rev-parse', '--short', 'HEAD']).trim();
      const ahead = git(dir, ['rev-list', '--count', '@{u}..HEAD']).trim();
      const behind = git(dir, ['rev-list', '--count', 'HEAD..@{u}']).trim();
      let bline = ` \x1b[1;32m${branch || '(detached)'}\x1b[0m`;
      if (ahead && ahead !== '0') bline += ` \x1b[36m↑${ahead}\x1b[0m`;
      if (behind && behind !== '0') bline += ` \x1b[33m↓${behind}\x1b[0m`;
      lines.push(bline);
      const status = git(dir, ['status', '--short']).split('\n').filter(Boolean);
      if (status.length) {
        lines.push('');
        lines.push(' \x1b[2mchanges\x1b[0m');
        const SHOW = 14;
        for (const s of status.slice(0, SHOW)) {
          const code = s.slice(0, 2);
          const file = s.slice(3);
          let color = '\x1b[37m';
          if (code.includes('?')) color = '\x1b[32m';
          else if (code.includes('M')) color = '\x1b[33m';
          else if (code.includes('A')) color = '\x1b[32m';
          else if (code.includes('D')) color = '\x1b[31m';
          else if (code.includes('R')) color = '\x1b[35m';
          lines.push(` ${color}${code}\x1b[0m ${file.slice(0, w - 5)}`);
        }
        if (status.length > SHOW) {
          lines.push(` \x1b[2m… +${status.length - SHOW} more\x1b[0m`);
        }
      } else {
        lines.push(' \x1b[2mworking tree clean\x1b[0m');
      }
      const log = git(dir, ['log', '--oneline', '--decorate=no', '-5']).split('\n').filter(Boolean);
      if (log.length) {
        lines.push('');
        lines.push(' \x1b[2mrecent\x1b[0m');
        for (const l of log) {
          const sp = l.indexOf(' ');
          const hash = sp > 0 ? l.slice(0, sp) : l;
          const msg = sp > 0 ? l.slice(sp + 1) : '';
          lines.push(` \x1b[33m${hash}\x1b[0m \x1b[2m${msg.slice(0, w - 10)}\x1b[0m`);
        }
      }
    }
    const body = lines.map(l => l + '\x1b[K').join('\n');
    if (body !== lastBody) {
      process.stdout.write(paintAltScreen(body));
      lastBody = body;
    }
  }
  render();
  const timer = setInterval(render, GIT_OVERLAY_TICK_MS);
  function exit() {
    try { process.stdout.write('\x1b[?1049l'); } catch {}
    clearInterval(timer);
    process.exit(0);
  }
  process.on('SIGTERM', exit);
  process.on('SIGINT', exit);
}

// ----- agent watcher daemon -----
//
// Polls every nmux window's pane process trees and detects whether an
// LLM agent (claude / codex / omx / gemini / aider) is currently alive
// inside. The window's @nmuxlinux_status reflects that detection:
//   agent appears      → "running"  (spinner)
//   agent disappears   → "done"     (✓)
//   user visits window → cleared back to "idle" by clear-status
// This bypasses the brittle hook-based path entirely — a hook only
// helps when the source tool fires one, runs in a TMUX-visible
// process, and routes to the right project. The watcher inspects the
// pane itself, so any agent in any window is seen consistently.

const AGENT_BINS = new Set(['claude', 'codex', 'omx', 'gemini', 'aider', 'continue', 'cursor']);

function looksLikeAgent(cmdline) {
  const c = String(cmdline || '').replace(/\0/g, ' ').trim();
  if (!c) return false;
  const parts = c.split(/\s+/);
  if (!parts.length) return false;
  const arg0 = (parts[0] || '').split('/').pop();
  if (AGENT_BINS.has(arg0)) return true;
  // Node wrappers: `node /path/to/<agent>`
  if (arg0 === 'node' && parts.length >= 2) {
    const sub = (parts[1] || '').split('/').pop();
    if (AGENT_BINS.has(sub)) return true;
  }
  return false;
}

function findAgentPidsInPane(rootPid, proc) {
  const agents = [];
  if (!rootPid) return agents;
  const stack = [String(rootPid)];
  const seen = new Set();
  while (stack.length) {
    const p = stack.pop();
    if (!p || seen.has(p)) continue;
    seen.add(p);
    if (looksLikeAgent(proc.commands.get(p))) agents.push(p);
    for (const child of proc.children.get(p) || []) stack.push(child);
  }
  return agents;
}

// Read cumulative CPU ticks (utime + stime) for a pid. Process is gone
// or unreadable → 0 (treated as "no activity recorded").
function readCpuTicks(pid) {
  try {
    const stat = fs.readFileSync(`/proc/${pid}/stat`, 'utf8');
    // After "<comm>) " the remaining fields start at the 3rd character
    // class (state); utime is field 14 (index 11), stime field 15 (12).
    const tail = stat.split(') ').pop().split(' ');
    const utime = parseInt(tail[11], 10) || 0;
    const stime = parseInt(tail[12], 10) || 0;
    return utime + stime;
  } catch { return 0; }
}

const WATCHER_PID_FILE = path.join(CONFIG_DIR, 'watcher.pid');

function watcherIsAlive() {
  try {
    if (!fs.existsSync(WATCHER_PID_FILE)) return false;
    const pid = parseInt(fs.readFileSync(WATCHER_PID_FILE, 'utf8'), 10);
    if (!Number.isFinite(pid)) return false;
    try { process.kill(pid, 0); return true; } catch { return false; }
  } catch { return false; }
}

function startWatcherDaemonIfNeeded() {
  if (watcherIsAlive()) return;
  try { fs.unlinkSync(WATCHER_PID_FILE); } catch {}
  const child = spawn(NMUX_BIN, ['watch-agents'],
    { detached: true, stdio: 'ignore' });
  child.unref();
}

function watchAgentsDaemon() {
  // Single-instance: refuse to start if another watcher is already alive.
  if (watcherIsAlive()) {
    console.error('[nmux-linux] watcher already running');
    process.exit(0);
  }
  ensureConfigDir();
  fs.writeFileSync(WATCHER_PID_FILE, String(process.pid));
  const cleanup = () => { try { fs.unlinkSync(WATCHER_PID_FILE); } catch {} };
  process.on('exit', cleanup);
  process.on('SIGTERM', () => { cleanup(); process.exit(0); });
  process.on('SIGINT',  () => { cleanup(); process.exit(0); });

  // Per-window "was active last tick" and per-pid CPU ticks at last
  // sample. Active = at least one agent in this window burned more than
  // CPU_ACTIVE_THRESHOLD ticks since the previous sample. Daemon-style
  // agents like `omx resume` / `codex resume` stay alive while idle —
  // process existence alone is not a useful signal, so we sample CPU
  // delta over a TICK_MS window instead.
  const prevQuietTicks = new Map();  // window_id -> consecutive idle ticks
  const prevCpu = new Map();         // pid -> cumulative ticks
  const prevPtyMtime = new Map();    // pane_tty -> last seen mtime (ms)
  const TICK_MS = Math.max(2000, Number(process.env.NMUX_WATCHER_TICK_MS || 3000));
  const CPU_ACTIVE_THRESHOLD = 60;   // ~600ms CPU/sample — heavy tool
                                     // execution only. Tuned higher
                                     // than 12 (previous value) because
                                     // codex/omx daemons emit periodic
                                     // CPU bursts of 15-25 ticks every
                                     // ~50s for token-counter / mcp-
                                     // heartbeat work; the old threshold
                                     // mis-classified those heartbeats
                                     // as "running", causing minute-
                                     // scale flip-flop. Real agent work
                                     // spikes well above 60 ticks. PTY
                                     // mtime carries the lighter signal
                                     // (streamed tokens / quick output)
                                     // since heartbeats never write to
                                     // the visible buffer.
  const QUIET_TICKS_TO_DONE = 4;     // running→done after ~12 idle seconds
                                     // by default. Long enough that an LLM
                                     // briefly thinking between bursts
                                     // doesn't flicker the indicator,
                                     // short enough that the user sees
                                     // ✓ within a few seconds of real
                                     // completion.
  const CLICK_GRACE_MS = 3000;       // window the user just clicked is
                                     // exempt from watcher decisions
                                     // for this many ms. Absorbs the
                                     // PTY redraw burst from select-
                                     // window / select-pane so the row
                                     // doesn't flip to "running" the
                                     // instant the user clicks it.
  //
  // Activity = (a) CPU delta on any agent pid ≥ CPU_ACTIVE_THRESHOLD,
  // OR (b) the pane's PTY mtime advanced this tick. Both signals are
  // gated by the click-grace check so user input (which also bumps
  // PTY) doesn't fake an agent running.
  const WATCHER_LOG = path.join(CONFIG_DIR, 'watcher.log');
  const WATCHER_LOG_MAX = 256 * 1024;
  function wlog(msg) {
    try {
      try {
        const st = fs.statSync(WATCHER_LOG);
        if (st.size > WATCHER_LOG_MAX) {
          const tail = fs.readFileSync(WATCHER_LOG).slice(-WATCHER_LOG_MAX / 2);
          fs.writeFileSync(WATCHER_LOG, tail);
        }
      } catch {}
      fs.appendFileSync(WATCHER_LOG, `${new Date().toISOString()} ${msg}\n`);
    } catch {}
  }

  function tick() {
    if (!sessionExists(SESSION)) { cleanup(); process.exit(0); }
    let out;
    try {
      out = tmux(['list-panes', '-s', '-t', SESSION, '-F',
        '#{window_id}\t#{window_index}\t#{pane_pid}\t#{pane_tty}\t#{pane_title}'],
        { allowFail: true });
    } catch { return; }
    const proc = readProcIndex();
    const byWin = new Map();
    for (const line of out.split('\n')) {
      if (!line) continue;
      const [wid, widx, ppid, ptty, title] = line.split('\t');
      if (title === 'nmux-linux-sidebar') continue;
      if (!byWin.has(wid)) byWin.set(wid, { idx: widx, ppids: [], ptys: [] });
      byWin.get(wid).ppids.push(ppid);
      byWin.get(wid).ptys.push(ptty);
    }
    // Forget windows that no longer exist.
    for (const wid of Array.from(prevQuietTicks.keys())) {
      if (!byWin.has(wid)) prevQuietTicks.delete(wid);
    }
    // Forget PTY mtime baselines for vanished panes so stale entries
    // don't pile up across long-running sessions.
    const liveTtys = new Set();
    for (const info of byWin.values()) for (const t of info.ptys) liveTtys.add(t);
    for (const t of Array.from(prevPtyMtime.keys())) {
      if (!liveTtys.has(t)) prevPtyMtime.delete(t);
    }
    // Garbage-collect prevCpu entries for pids that vanished.
    const livePids = new Set();
    for (const [, info] of byWin) {
      for (const ppid of info.ppids) {
        for (const apid of findAgentPidsInPane(ppid, proc)) livePids.add(apid);
      }
    }
    for (const pid of Array.from(prevCpu.keys())) {
      if (!livePids.has(pid)) prevCpu.delete(pid);
    }
    const now = Date.now();
    for (const [wid, info] of byWin) {
      const target = `${SESSION}:${info.idx}`;
      // Click grace: if the user clicked this window within the last
      // CLICK_GRACE_MS, skip the watcher entirely for this tick. This
      // also rebases the PTY mtime so the redraw burst from the click
      // doesn't register as activity on the next tick either.
      const clickedAtStr = tmux(['show-window-options', '-t', target, '-v',
        '@nmuxlinux_clicked_at'], { allowFail: true }).trim();
      const clickedAt = parseInt(clickedAtStr, 10);
      if (Number.isFinite(clickedAt) && now - clickedAt < CLICK_GRACE_MS) {
        for (const ptty of info.ptys) {
          if (!ptty || ptty === '-') continue;
          try { prevPtyMtime.set(ptty, fs.statSync(ptty).mtimeMs); } catch {}
        }
        // Sample CPU baselines so we have fresh prev values once grace ends.
        for (const apid of info.ppids.flatMap(pid => findAgentPidsInPane(pid, proc))) {
          prevCpu.set(apid, readCpuTicks(apid));
        }
        continue;
      }
      const agents = info.ppids.flatMap(pid => findAgentPidsInPane(pid, proc));
      let active = false;
      const trigger = [];
      // (a) CPU delta on any agent process
      for (const apid of agents) {
        const cur = readCpuTicks(apid);
        const prev = prevCpu.get(apid);
        prevCpu.set(apid, cur);
        if (prev != null) {
          const delta = cur - prev;
          if (delta >= CPU_ACTIVE_THRESHOLD) {
            active = true;
            trigger.push(`cpu ${apid}:${delta}`);
          }
        }
      }
      // (b) PTY mtime advanced this tick — agent producing output.
      // Single-tick bump now counts (we removed the two-in-a-row rule
      // because LLM streams often have 1-tick stream / 1-tick pause /
      // 1-tick stream patterns that the old rule misread as idle).
      // The click-grace branch above absorbs the one-off PTY burst
      // caused by tmux redrawing a freshly-selected pane, so a bare
      // user click no longer false-triggers here.
      if (agents.length) {
        const PTY_MAX_GAP_MS = 30000;
        for (const ptty of info.ptys) {
          if (!ptty || ptty === '-') continue;
          let mt = 0;
          try { mt = fs.statSync(ptty).mtimeMs; } catch { continue; }
          const prev = prevPtyMtime.get(ptty);
          prevPtyMtime.set(ptty, mt);
          if (prev != null && mt > prev) {
            const gap = mt - prev;
            // Real LLM streams / live tool output bump PTY mtime every
            // tick or two (sub-second cadence). Gaps over PTY_MAX_GAP_MS
            // (30s) almost always come from one-off background
            // chatter — token-usage poll, mcp heartbeat, status-bar
            // refresh — not user-visible agent work. Treat them as
            // idle so the sidebar doesn't flip-flop every few minutes.
            if (gap < PTY_MAX_GAP_MS) {
              active = true;
              trigger.push(`pty ${ptty}:+${Math.round(gap)}ms`);
            }
          }
        }
      }
      const curStatus = tmux(['show-window-options', '-t', target, '-v', '@nmuxlinux_status'],
        { allowFail: true }).trim();
      const prevQuiet = prevQuietTicks.get(wid) ?? 0;
      if (active) {
        prevQuietTicks.set(wid, 0);
        if (curStatus === 'idle' || curStatus === 'done' || curStatus === '') {
          setWindowStatus(target, 'running', undefined, { allowFail: true });
          wlog(`w=${info.idx} idle→running agents=${agents.length} trigger=${trigger.join('|')}`);
        } else if (curStatus === 'running') {
          // Keep live running statuses fresh. Sidebars intentionally hide
          // old/unstamped running options so a crashed watcher or legacy
          // tmux option cannot animate forever.
          setWindowStatus(target, 'running', undefined, { allowFail: true });
        }
      } else {
        const nq = prevQuiet + 1;
        prevQuietTicks.set(wid, nq);
        // Only drop running→done after N consecutive idle ticks. This
        // is hysteresis: a single quiet tick between LLM token bursts
        // no longer flickers the indicator. Other states (need-input,
        // failed) are never overwritten by the watcher.
        if (curStatus === 'running' && nq >= QUIET_TICKS_TO_DONE) {
          setWindowStatus(target, 'done', undefined, { allowFail: true });
          wlog(`w=${info.idx} running→done (quiet ${nq} ticks)`);
        }
      }
    }
  }

  // First tick can't decide activity (no previous CPU sample), so just
  // populate baseline. Second tick onwards has meaningful deltas.
  tick();
  setInterval(tick, TICK_MS);
}

// After window-switch, focus the project's main shell pane so the user
// lands in code rather than on the sidebar/right column.
// Pane titling: every non-sidebar pane in a project window is named
// `<project>-<role>` so the user can tell at a glance which slot
// belongs to which project. Role suffixes are stable so JS lookups
// can identify a pane by its purpose even when the project name
// contains hyphens. Legacy hardcoded titles ('right-top', etc.) are
// still recognized for windows built before this change.
const PANE_ROLE_SUFFIX = {
  main: '-main', sub: '-sub', status: '-status', bash: '-bash', webview: '-webview',
};
function paneTitleFor(project, role) {
  if (!project || !PANE_ROLE_SUFFIX[role]) return '';
  return project + PANE_ROLE_SUFFIX[role];
}
// Strip escape/control noise out of a pane_title before we use it for role
// routing. Some agents emit kitty-graphics APC sequences (`\e_G...\e\\`) that
// the host terminal/tmux fails to consume, so the raw payload (`Gm=0;<base64>`,
// or leftover ESC/control bytes) ends up parked in #{pane_title}. Feeding that
// straight into paneRoleOf is what leaks the "wall of garbage". Drop control
// bytes and collapse a bare kitty-graphics payload to empty so it resolves to
// the main pane (role null) cleanly.
function sanitizeTitle(title) {
  if (!title) return '';
  let s = String(title)
    // OSC / DCS / APC / PM / SOS and lone ESC sequences.
    .replace(/\x1b[\]_^PX][\s\S]*?(?:\x1b\\|\x07|$)/g, '')
    .replace(/\x1b\[[0-9;?]*[ -\/]*[@-~]/g, '')
    .replace(/\x1b./g, '')
    // Any remaining C0/C1 control bytes.
    .replace(/[\x00-\x1f\x7f-\x9f]/g, '');
  // Bare kitty-graphics APC payload that leaked into the title verbatim.
  if (/^G[A-Za-z]=[^;]*;/.test(s)) return '';
  return s;
}

// Resolve a pane's title from its (trusted) pane id, sanitized. Mouse/wheel
// bindings pass only #{pane_id} through the shell — never #{pane_title} —
// because an app-controlled title can contain quotes/control bytes that
// would break the run-shell quoting. display-message captures the raw
// title as a single spawnSync arg (no shell), so it stays inert here.
function paneTitleOf(pid) {
  if (!pid) return '';
  const r = spawnSync('tmux', ['display-message', '-p', '-t', pid, '#{pane_title}'],
    { encoding: 'utf8' });
  if (r.status !== 0) return '';
  return sanitizeTitle((r.stdout || '').replace(/\n$/, ''));
}
function paneRoleOf(title) {
  if (!title) return null;
  if (title === 'nmux-linux-sidebar') return 'sidebar';
  // Legacy hardcoded titles — still seen on windows that were built
  // before the project-prefixed naming convention. Keep matching
  // them so refreshOverlays / resize-cols / click routing all still
  // work on old layouts.
  if (title === 'right-top') return 'status';
  if (title === 'right-bot') return 'bash';
  if (title === 'code-mid') return 'sub';
  if (title === 'webview') return 'webview';
  for (const [role, sfx] of Object.entries(PANE_ROLE_SUFFIX)) {
    if (title.endsWith(sfx)) return role;
  }
  return null; // unknown — caller decides (usually means "treat as main")
}
function isReservedPaneTitle(title) {
  const r = paneRoleOf(title);
  return r !== null && r !== 'main';
}
// Legacy back-compat alias — keep code that imports the set working.
const RESERVED_PANE_TITLES = {
  has: t => isReservedPaneTitle(t),
};
function focusMainPane(target) {
  const out = tmux(['list-panes', '-t', target, '-F', '#{pane_id}\t#{pane_title}\t#{pane_pid}'],
    { allowFail: true });
  for (const line of out.split('\n')) {
    if (!line) continue;
    const [pid, title, ppid] = line.split('\t');
    if (RESERVED_PANE_TITLES.has(title)) continue;
    if (isSidebarPid(ppid)) continue;
    tmux(['select-pane', '-t', pid], { allowFail: true });
    return;
  }
}

// ---------- notify ----------
function findWindowForProject(session, project) {
  const out = tmux(['list-windows', '-t', session, '-F',
    '#{window_index}\t#{window_name}\t#{@nmuxlinux_project}'], { allowFail: true });
  for (const line of out.split('\n')) {
    if (!line) continue;
    const [idx, name, proj] = line.split('\t');
    const cleanName = (name || '').replace(/^[✓✕?…! ]+\s*/, '');
    if (proj === project || cleanName === project || name === project) return `${session}:${idx}`;
  }
  return null;
}

function notify({ project, status, message = '', session = SESSION }) {
  if (!project) throw new Error('--project required');
  status = String(status || 'done');
  let target = null;
  if (sessionExists(session)) {
    target = findWindowForProject(session, project);
    if (target) {
      setWindowStatus(target, status, message);
    }
  }
  // Log every notify so wrong-routing (e.g. PreToolUse from one Claude
  // instance landing on the wrong project window) is debuggable after
  // the fact. Uses the same rotating log writer as click events.
  logClick(`notify project=${project} status=${status} target=${target || 'NO-MATCH'} caller_pane=${process.env.TMUX_PANE || '-'} caller_cwd=${process.env.PWD || '-'} msg=${(message || '').slice(0, 60)}`);
  fireDesktop(project, status, message);
  return { project, status, message, session };
}

function fireDesktop(project, status, message) {
  try {
    if (which('notify-send')) {
      const urgency = status === 'failed' ? 'critical' : status === 'need-input' ? 'normal' : 'low';
      const icon = status === 'failed' ? 'dialog-error'
                  : status === 'need-input' ? 'dialog-question'
                  : 'dialog-information';
      const env = { ...process.env };
      if (!env.DBUS_SESSION_BUS_ADDRESS && fs.existsSync(`/run/user/${process.getuid()}/bus`)) {
        env.DBUS_SESSION_BUS_ADDRESS = `unix:path=/run/user/${process.getuid()}/bus`;
      }
      spawnSync('notify-send', ['-u', urgency, '-i', icon,
        `[nmux-linux] ${project} — ${status}`, message || ''], { env });
    }
  } catch {}
  try {
    const ok = ['/usr/share/sounds/freedesktop/stereo/complete.oga',
                '/usr/share/sounds/freedesktop/stereo/bell.oga'];
    const bad = ['/usr/share/sounds/freedesktop/stereo/dialog-error.oga'];
    const file = (status === 'failed' ? bad : ok).find(fs.existsSync);
    if (file && which('paplay')) spawnSync('paplay', [file], { stdio: 'ignore', detached: true });
  } catch {}
}

function clearStatus(project) {
  if (!project) return;
  if (!sessionExists(SESSION)) return;
  const target = findWindowForProject(SESSION, project);
  if (!target) return;
  clearStatusTarget(target);
}

function clearStatusTarget(target) {
  if (!target) return;
  // Preserve "running" across a window-visit. The after-select-window
  // hook fires clear-status on every visit, which is right for the
  // "I saw the ✓ / ✕ / ?" terminal states — the user has acknowledged
  // them, drop the indicator. But for "running" the spinner is the
  // user's live signal that work is still in flight. Only fresh running
  // statuses are preserved; old/unstamped ones are stale and were the
  // source of permanent spinners and fast sidebar repainting.
  const cur = tmux(['show-window-options', '-t', target, '-v', '@nmuxlinux_status'],
    { allowFail: true }).trim();
  if (cur === 'running' && runningStatusIsFresh(target) && targetHasAgentProcess(target)) return;
  setWindowStatus(target, 'idle', '', { allowFail: true });
}

function targetHasAgentProcess(target) {
  const panes = tmux(['list-panes', '-t', target, '-F', '#{pane_pid}\t#{pane_title}'],
    { allowFail: true });
  if (!panes) return false;
  const proc = readProcIndex();
  for (const line of panes.split('\n')) {
    if (!line) continue;
    const [rootPid, title] = line.split('\t');
    if (paneRoleOf(title) === 'sidebar') continue;
    if (findAgentPidsInPane(rootPid, proc).length) return true;
  }
  return false;
}

function currentNmuxWindowTarget() {
  if (process.env.TMUX) {
    const info = tmux(['display-message', '-p', '#{session_name}\t#{window_index}'], { allowFail: true });
    const [s, idx] = info.split('\t');
    if (s === SESSION && idx) return `${SESSION}:${idx}`;
  }
  const active = tmux(['list-windows', '-t', SESSION, '-F', '#{?window_active,#{window_index},}'], { allowFail: true })
    .split('\n').find(Boolean);
  const idx = active || (tmux(['list-windows', '-t', SESSION, '-F', '#{window_index}'], { allowFail: true }).split('\n')[0] || '').trim();
  return idx ? `${SESSION}:${idx}` : null;
}

function listPaneInfo(target) {
  const out = tmux(['list-panes', '-t', target, '-F',
    '#{pane_id}\t#{pane_title}\t#{pane_current_path}\t#{pane_current_command}\t#{pane_pid}'],
    { allowFail: true });
  return out.split('\n').filter(Boolean).map(line => {
    const [pid, title, cwd, cmd, rootPid] = line.split('\t');
    return { pid, title, cwd, cmd, rootPid };
  });
}

function findMainPane(panes, projectName = '') {
  return panes.find(p => p.title === paneTitleFor(projectName, 'main'))
    || panes.find(p => p.title === projectName) // legacy plain-name
    || panes.find(p => paneRoleOf(p.title) === null || paneRoleOf(p.title) === 'main')
    || panes[0];
}

function isLikelyUrl(s) {
  return /^(https?:\/\/|file:\/\/|localhost[:/]|127\.0\.0\.1[:/])/.test(String(s || ''));
}

function previewHelp() {
  return 'usage: nmux-linux preview [--external|--cmd] [--focus] <url|command>';
}

function previewCommand(args) {
  if (!sessionExists(SESSION)) throw new Error('nmux-linux session is not running');
  const flagValue = typeof args.cmd === 'string' ? args.cmd
    : typeof args.external === 'string' ? args.external
      : typeof args.focus === 'string' ? args.focus
      : '';
  const input = (flagValue || args._.slice(1).join(' ')).trim();
  if (!input) throw new Error(previewHelp());
  const target = currentNmuxWindowTarget();
  if (!target) throw new Error('no nmux-linux window found');

  const panes = listPaneInfo(target);
  const rightTop = panes.find(p => paneRoleOf(p.title) === 'status' || paneRoleOf(p.title) === 'webview');
  if (!rightTop) throw new Error('status pane not found; run `nmux-linux relayout` first');
  const info = tmux(['display-message', '-p', '-t', target, '#{@nmuxlinux_project}\t#{pane_current_path}'], { allowFail: true });
  const [projectName] = info.split('\t');
  const main = findMainPane(panes, projectName);

  if (args.external) {
    const opener = which('xdg-open');
    if (!opener) throw new Error('xdg-open not found; install xdg-utils or run `nmux-linux preview --cmd <command>`');
    spawnSync(opener, [input], { detached: true, stdio: 'ignore' });
    userMsg(`nmux-linux: opened externally ${input}`, 2500);
    if (!args.focus && main) tmux(['select-pane', '-t', main.pid], { allowFail: true });
    return;
  }

  let cmd;
  if (args.cmd || !isLikelyUrl(input)) {
    cmd = input;
  } else {
    const browser = ['w3m', 'lynx', 'elinks', 'links'].map(which).find(Boolean);
    if (!browser) {
      throw new Error('no terminal browser found (w3m, lynx, elinks, links). Install one, use `--external`, or use `--cmd <command>`.');
    }
    cmd = `${shQuote(browser)} ${shQuote(input)}`;
  }

  const cwd = rightTop.cwd || (main && main.cwd) || HOME;
  const shell = process.env.SHELL || '/bin/bash';
  tmux(['respawn-pane', '-k', '-t', rightTop.pid, '-c', cwd,
    `bash -lc ${shEsc(`printf '\\033]2;webview\\033\\\\'; exec ${shell} -lc ${shQuote(cmd)}`)}`],
    { allowFail: false });
  tmux(['select-pane', '-t', rightTop.pid, '-T', paneTitleFor(projectName, 'webview')], { allowFail: true });
  if (args.focus) tmux(['select-pane', '-t', rightTop.pid], { allowFail: true });
  else if (main) tmux(['select-pane', '-t', main.pid], { allowFail: true });
  userMsg(`nmux-linux: preview in right-top`, 2500);
}

function notifyCurrent(opts) {
  let project = opts.project;
  // Always notify into the nmux-linux session — that's where the sidebar
  // lives. The caller (Claude / omx hook) may be running in any tmux
  // session (or none); we resolve which nmux project this should hit by
  // looking at the caller's pane_current_path and matching it against
  // the registered project list. Without this, a Claude instance running
  // in `_bootstrap` would set status on its own (sidebar-less) session
  // and silently never reach the user's sidebar.
  const session = opts.session || SESSION;
  if (!project && process.env.TMUX) {
    try {
      const info = tmux(['display-message', '-p',
        '#{@nmuxlinux_project}\t#{window_name}\t#{pane_current_path}']);
      const [proj, win, cwd] = info.split('\t');
      // 1) Direct: caller pane is inside an nmux-linux window
      project = (proj || '').trim();
      // 2) Indirect: caller pane is anywhere on disk, but its cwd
      //    matches (or is inside) a registered project directory
      if (!project && cwd) {
        try {
          const cfg = loadConfig();
          const projects = (cfg && cfg.projects) || [];
          const match = projects
            .filter(p => p.cwd && (cwd === p.cwd || cwd.startsWith(p.cwd + '/')))
            // Prefer the deepest match so a nested project beats its parent
            .sort((a, b) => b.cwd.length - a.cwd.length)[0];
          if (match) project = match.name;
        } catch {}
      }
      // 3) Last resort: cleaned window name
      if (!project) project = (win || '').replace(/^[✓✕?…! ]+\s*/, '').trim();
    } catch {}
  }
  // No active-window fallback: that would route external Claude/omx
  // hooks (TMUX env absent, cwd matches nothing) onto whatever window
  // the user happens to be looking at — flagging unrelated projects
  // as "running". The agent watcher daemon (`watch-agents`) handles
  // detection from process trees instead; this resolver only fires
  // status when we can attribute it to a real project.
  if (!project) project = 'unknown';
  return notify({ ...opts, project, session });
}

// ---------- ops ----------
function status() {
  if (!sessionExists(SESSION)) { console.log('nmux-linux session: (not running)'); return; }
  const out = tmux(['list-windows', '-t', SESSION, '-F',
    '#{window_index}\t#{window_name}\t#{@nmuxlinux_status}\t#{@nmuxlinux_project}\t#{@nmuxlinux_message}']);
  const proc = readProcIndex();
  console.log(`nmux-linux session: ${SESSION}`);
  for (const line of out.split('\n')) {
    if (!line) continue;
    const [idx, name, st, proj, msg] = line.split('\t');
    console.log(`  ${idx}. [${st || 'idle'}] ${proj || name}${msg ? ' — ' + msg : ''}`);
    const panes = tmux(['list-panes', '-t', `${SESSION}:${idx}`, '-F',
      '#{pane_id}\t#{pane_title}\t#{pane_current_command}\t#{pane_pid}'],
      { allowFail: true });
    for (const pLine of panes.split('\n')) {
      if (!pLine) continue;
      const [paneId, title, cmd, rootPid] = pLine.split('\t');
      const hud = paneIsOmxHud(rootPid, proc, cmd) ? ' [OMX-HUD]' : '';
      console.log(`      ${paneId} ${title || '(untitled)'} (${cmd || '?'})${hud}`);
    }
  }
  const state = loadState();
  console.log(`open-set persisted: ${(state.open || []).join(', ') || '(none)'}`);
}

function killSession() {
  if (sessionExists(SESSION)) {
    captureAndSaveOpen(SESSION);
    tmux(['kill-session', '-t', SESSION]);
  }
}
function addProject(name, dir) {
  if (!name || !dir) throw new Error('usage: nmux-linux add <name> <path>');
  const abs = path.resolve(dir);
  if (!fs.existsSync(abs)) throw new Error(`not found: ${abs}`);
  let cfg = loadConfig() || initConfig();
  if (cfg.projects.find(p => p.name === name)) throw new Error(`already exists: ${name}`);
  cfg.projects.push(defaultProject(name, abs));
  saveConfig(cfg);
  console.log(`added: ${name} -> ${abs}`);
}
function rmProject(name) {
  let cfg = loadConfig();
  if (!cfg) throw new Error('no config');
  const before = cfg.projects.length;
  cfg.projects = cfg.projects.filter(p => p.name !== name);
  if (cfg.projects.length === before) throw new Error(`not found: ${name}`);
  saveConfig(cfg);
  const st = loadState();
  st.open = (st.open || []).filter(n => n !== name);
  saveState(st);
  console.log(`removed: ${name}`);
}

// ---------- args ----------
function parseArgs(argv) {
  const out = { _: [] };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (!a.startsWith('--')) { out._.push(a); continue; }
    const key = a.slice(2);
    const next = argv[i + 1];
    if (next === undefined || next.startsWith('--')) { out[key] = true; }
    else { out[key] = next; i++; }
  }
  return out;
}

function main() {
  const args = parseArgs(process.argv.slice(2));
  const cmd = args._[0] || 'launch';
  if (cmd === 'help' || args.help) { console.log(HELP); return; }
  if (cmd === 'init')      { const cfg = initConfig({ force: args.force }); console.log(`config: ${CONFIG_PATH} (${cfg.projects.length} projects)`); return; }
  if (cmd === 'apply')     { applySession({ replace: Boolean(args.replace) }); startWatcherDaemonIfNeeded(); console.log(`session ${SESSION} ready`); return; }
  if (cmd === 'launch')    { if (!fs.existsSync(CONFIG_PATH)) initConfig(); applySession({ replace: false }); startWatcherDaemonIfNeeded(); attach(SESSION); return; }
  if (cmd === 'refresh')   { if (sessionExists(SESSION)) installBindings(SESSION); startWatcherDaemonIfNeeded(); console.log('bindings reapplied'); return; }
  if (cmd === 'refresh-sidebars') { refreshSidebars(); return; }
  if (cmd === 'status')    { status(); return; }
  if (cmd === 'kill')      { killSession(); console.log('killed'); return; }
  if (cmd === 'confirm-kill') { confirmKill(); return; }
  if (cmd === 'click')     { clickHandler(args._[1], args._[2], args._[3]); return; }
  if (cmd === 'click-url') { clickUrlAtPane(args._[1], args._[2]); return; }
  if (cmd === 'task-overlay') { taskOverlayDaemon(args.cwd); return; }
  if (cmd === 'task-scroll') {
    // Args: <up|down|top> <pane_id>
    const dir = (args._[1] || '').toLowerCase();
    const pid = args._[2];
    if (pid && (dir === 'up' || dir === 'down' || dir === 'top')) {
      appendTaskEvent(pid, `SCROLL ${dir.toUpperCase()}`);
    }
    return;
  }
  if (cmd === 'task-click') {
    // Args: <mouse_y> <pane_id>
    const y = parseInt(args._[1], 10);
    const pid = args._[2];
    if (Number.isFinite(y) && pid) appendTaskEvent(pid, `CLICK ${y}`);
    return;
  }
  if (cmd === 'mouseup') {
    // Args: <pane_id> <session> <mouse_y> <mouse_x>
    // Dispatches the click:
    //   sidebar  → project click
    //   status   → task-overlay row click → jump main pane
    //   else      → just select the pane
    const pid = args._[1];
    const sess = args._[2];
    const y = parseInt(args._[3], 10);
    const x = parseInt(args._[4], 10);
    const title = paneTitleOf(pid);
    if (!pid) return;
    if (sess === SESSION) {
      const role = paneRoleOf(title);
      if (role === 'sidebar') {
        clickHandler(String(y), String(x), pid);
        return;
      }
      if (role === 'status') {
        if (Number.isFinite(y)) appendTaskEvent(pid, `CLICK ${y}`);
        return;
      }
    }
    // Default: just select the clicked pane.
    spawnSync('tmux', ['select-pane', '-t', pid], { stdio: 'ignore' });
    return;
  }
  if (cmd === 'wheel') {
    // Args: <up|down> <pane_id> <session> <pane_in_mode> <mouse_any_flag>
    // Dispatches the wheel event:
    //   sidebar  → swallow
    //   right-top → forward to task-overlay event queue
    //   else      → re-issue tmux's stock wheel behaviour
    const dir = (args._[1] || '').toLowerCase();
    const pid = args._[2];
    const sess = args._[3];
    const inMode = args._[4] === '1';
    const mouseAny = args._[5] === '1';
    const title = paneTitleOf(pid);
    if (!pid) return;
    if (sess === SESSION) {
      const role = paneRoleOf(title);
      if (role === 'sidebar') return; // swallow
      if (role === 'status') {
        appendTaskEvent(pid, `SCROLL ${dir.toUpperCase()}`);
        return;
      }
    }
    // Stock behaviour: if pane is in copy-mode or has mouse passthrough,
    // forward the raw mouse event; otherwise wheel-up enters copy-mode
    // (so the user sees scrollback) and wheel-down forwards to the app.
    if (inMode || mouseAny) {
      spawnSync('tmux', ['send-keys', '-t', pid, '-M'], { stdio: 'ignore' });
    } else if (dir === 'up') {
      spawnSync('tmux', ['copy-mode', '-e', '-t', pid], { stdio: 'ignore' });
    } else {
      spawnSync('tmux', ['send-keys', '-t', pid, '-M'], { stdio: 'ignore' });
    }
    return;
  }
  if (cmd === 'git-overlay') { gitOverlayDaemon(args.cwd); return; }
  if (cmd === 'refresh-overlays') { refreshOverlays(); return; }
  if (cmd === 'relayout-3col') { relayout3col(); return; }
  if (cmd === 'resize-cols') { resizeCols(); return; }
  if (cmd === 'watch-agents') { watchAgentsDaemon(); return; }
  if (cmd === 'kill-watcher') {
    try {
      const pid = parseInt(fs.readFileSync(WATCHER_PID_FILE, 'utf8'), 10);
      if (Number.isFinite(pid)) process.kill(pid, 'SIGTERM');
    } catch {}
    return;
  }
  if (cmd === 'prompt')    { promptCommand(); return; }
  if (cmd === 'open')      { openProject(args._[1]); return; }
  if (cmd === 'close-window') { closeWindow(args._[1]); return; }
  if (cmd === 'close-current') { closeCurrent(); return; }
  if (cmd === 'relayout-current' || cmd === 'relayout') { relayoutCurrent(); return; }
  if (cmd === 'fix-layout') { fixLayout(); return; }
  if (cmd === 'clean-omx-hud') { console.log(`killed ${killOmxHudPanes()} omx HUD pane(s)`); return; }
  if (cmd === 'preview' || cmd === 'webview') { previewCommand(args); return; }
  if (cmd === 'disable-omx-hud') { disableOmxHud(); return; }
  if (cmd === 'enable-omx-hud') { enableOmxHud(); return; }
  if (cmd === 'save-state'){ captureAndSaveOpen(SESSION); console.log('state saved'); return; }
  if (cmd === 'notify')    { const r = notify({ project: args.project, status: args.status, message: args.message, session: args.session }); console.log(`${r.project}: ${r.status}`); return; }
  if (cmd === 'notify-current') { const r = notifyCurrent({ status: args.status, message: args.message, session: args.session, project: args.project }); console.log(`${r.project}: ${r.status}`); return; }
  if (cmd === 'clear-status') { clearStatus(args.project); return; }
  if (cmd === 'add')       { addProject(args._[1], args._[2]); return; }
  if (cmd === 'rm')        { rmProject(args._[1]); return; }
  console.error('Unknown command: ' + cmd);
  console.error(HELP);
  process.exit(2);
}

if (require.main === module) {
  try { main(); }
  catch (e) { console.error('[nmux-linux] ' + (e.message || e)); process.exit(1); }
} else {
  module.exports = {
    clipDisplayText,
    computeResponsiveLayout,
    responsiveSidebarWidth,
    statusKoreanLabel,
    renderTaskOverlaySummaryLines,
    renderNoTaskFallbackLines,
    sanitizeTitle,
    paneRoleOf,
  };
}
